              <div style={{width:'100%',height:'82px',borderRadius:'14px',background:c.h,marginBottom:'10px',

                border:c.n==='White'?'1px solid #374151':'none'}}/>

              <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.85rem'}}>{c.n}</div>

              <div style={{color:'#5eead4',fontSize:'.75rem'}}>{c.k}</div>

            </div>

          )

        })}

      </div>

      {sel&&(

        <div style={{...card({marginTop:'16px',display:'flex',gap:'16px',alignItems:'center',

          background:'rgba(99,102,241,0.06)',border:'1px solid rgba(99,102,241,0.25)',flexWrap:'wrap'})}}>

          <div style={{width:'80px',height:'80px',borderRadius:'14px',background:sel.h,flexShrink:0,

            border:sel.n==='White'?'1px solid #374151':'none'}}/>

          <div>

            <div style={{fontSize:'1.4rem',fontWeight:800,color:'#f9fafb'}}>{sel.e} {sel.n}</div>

            <div style={{color:'#5eead4',fontSize:'.9rem',marginBottom:'4px'}}>Kiswahili: <strong>{sel.k}</strong></div>

            <div style={{color:'#9ca3af',fontSize:'.8rem'}}>Hex code: <span style={{fontFamily:'monospace',color:'#a5b4fc'}}>{sel.h}</span></div>

          </div>

        </div>

      )}

    </div>

  )

}



/* ── PATTERNS ── */

function PatternsSection(){

  const patterns=[

    {seq:['🔴','🔵','🔴','🔵','🔴','🔵'],next:'🔴'},

    {seq:['🟡','🟡','🟢','🟡','🟡','🟢'],next:'🟡'},

    {seq:['⭐','🔷','🔶','⭐','🔷','🔶'],next:'⭐'},

    {seq:['🐱','🐕','🐕','🐱','🐕','🐕'],next:'🐱'},

    {seq:['🔺','🔶','🔺','🔺','🔶','🔺'],next:'🔺'},

  ]

  const [revealed,setRevealed]=useState({})

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Patterns — Mfumo</p>

      {patterns.map((p,i)=>(

        <div key={i} style={{...card({marginBottom:'12px',padding:'16px'})}}>

          <p style={{...label,marginBottom:'8px',color:'#9ca3af'}}>Pattern {i+1} — What comes next?</p>

          <div style={{display:'flex',gap:'8px',alignItems:'center',flexWrap:'wrap',marginBottom:'10px'}}>

            {p.seq.map((s,j)=>(

              <span key={j} style={{fontSize:'1.8rem'}}>{s}</span>

            ))}

            <span style={{fontSize:'1.5rem',color:'#374151'}}>→</span>

            <div onClick={()=>setRevealed(r=>({...r,[i]:true}))}

              style={{width:'44px',height:'44px',borderRadius:'10px',

                background:revealed[i]?'transparent':'rgba(99,102,241,0.15)',

                border:`2px dashed ${revealed[i]?'transparent':'#6366f1'}`,

                display:'flex',alignItems:'center',justifyContent:'center',cursor:'pointer',fontSize:'1.8rem'}}>

              {revealed[i]?p.next:'?'}

            </div>

          </div>

          {!revealed[i]&&<p style={{fontSize:'.75rem',color:'#6b7280',margin:0}}>Tap the "?" to reveal the answer!</p>}

        </div>

      ))}

    </div>

  )

}



/* ── ANIMALS ── */

function AnimalsSection({type}){

  const [flipped,setFlipped]=useState({})

  const all=type==='wild'?WILD_ANIMALS:type==='domestic'?DOMESTIC_ANIMALS:[...WILD_ANIMALS,...DOMESTIC_ANIMALS]

  const isWild=(n)=>WILD_ANIMALS.some(a=>a.n===n)

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>

        {type==='wild'?'🦁 Wild Animals — Wanyama Pori':type==='domestic'?'🐄 Domestic Animals — Wanyama wa Nyumbani':'🐾 Wild & Domestic Animals'}

      </p>

      <div style={grid('160px','12px')}>

        {all.map(a=>{

          const isF=flipped[a.n]

          const wild=isWild(a.n)

          const col=wild?'#f97316':'#22c55e'

          return(

            <div key={a.n} onClick={()=>setFlipped(f=>({...f,[a.n]:!f[a.n]}))}

              style={{...card({cursor:'pointer',textAlign:'center',padding:'16px',minHeight:'220px',

                display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',gap:'6px',

                border:`1px solid ${isF?col+'60':'#1f2937'}`,

                background:isF?col+'10':'#1a2234',transition:'all .2s'})}}>

              {!isF?(

                <>

                  <div style={{fontSize:'5.5rem',lineHeight:1.1,marginBottom:'4px'}}>{a.e}</div>

                  <div style={{fontWeight:800,color:'#f9fafb',fontSize:'1.1rem',marginTop:'6px'}}>{a.n}</div>

                  <div style={{...badge(col,{fontSize:'.65rem'}),marginTop:'2px'}}>{wild?'Wild':'Domestic'}</div>

                  <div style={{fontSize:'.7rem',color:'#6b7280',marginTop:'2px'}}>Tap to flip ↻</div>

                </>

              ):(

                <>

                  <div style={{fontWeight:700,color:col,fontSize:'1rem'}}>{a.k}</div>

                  <div style={{color:'#fdba74',fontSize:'.9rem',fontWeight:600}}>{a.s}</div>

                  <div style={{color:'#6b7280',fontSize:'.7rem',marginTop:'4px'}}>

                    {wild?`Habitat: ${a.h}`:`Use: ${a.u}`}

                  </div>

                </>

              )}

            </div>

          )

        })}

      </div>

      <p style={{color:'#6b7280',fontSize:'.75rem',marginTop:'10px',textAlign:'center'}}>

        Tap any card to flip it and see the Swahili name & sound!

      </p>

    </div>

  )

}



/* ── BODY PARTS ── */

function BodyPartsSection(){

  const [sel,setSel]=useState(null)

  return(

