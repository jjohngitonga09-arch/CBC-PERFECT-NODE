        {words.map(w=>{

          const isSel=sel?.w===w.w

          return(

            <div key={w.w} onClick={()=>setSel(isSel?null:w)}

              style={{...card({cursor:'pointer',textAlign:'center',padding:'12px 8px',

                border:`2px solid ${isSel?'#3b82f6':'#1f2937'}`,

                background:isSel?'rgba(59,130,246,0.12)':'#1a2234',transition:'all .15s'})}}>

              <div style={{fontSize:'2.6rem',marginBottom:'6px'}}>{w.e}</div>

              <div style={{fontWeight:900,color:'#93c5fd',fontSize:'1.3rem',fontFamily:'monospace'}}>{w.w}</div>

            </div>

          )

        })}

      </div>

      {sel&&(

        <div style={{...card({marginTop:'14px',background:'rgba(59,130,246,0.08)',border:'1px solid rgba(59,130,246,0.25)',textAlign:'center',padding:'20px'})}}>

          <div style={{fontSize:'3.5rem',marginBottom:'8px'}}>{sel.e}</div>

