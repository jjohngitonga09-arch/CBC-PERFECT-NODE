const CURRICULUM_NOTES = {

  alphabet:{

    title:'Language — Alphabet',

    outcomes:['Articulate all 26 uppercase and lowercase letters correctly','Match each letter to a word beginning with that letter','Begin to blend simple sounds into syllables (phonics)'],

    inquiries:['What letter is this? What sound does it make?','Which things in our classroom begin with the sound /b/?','Can you name a word for every letter of the alphabet?'],

    tip:'💡 Tip: Sing the alphabet song slowly, pointing to each letter on the chart!'

  },

  vowels:{

    title:'Language — Vowels (Irabu) & Consonants (Konsonanti)',

    outcomes:['Identify and name the 5 vowels: A E I O U (irabu)','Distinguish vowels from consonants (konsonanti)','Understand that every syllable must contain a vowel'],

    inquiries:['Which letters are vowels (irabu)? Can you name all five?','Is the letter B a vowel or a consonant?','How many vowels can you find in the word "elephant"?'],

    tip:'💡 Tip: Vowels are the "singing" sounds — A E I O U. Every word needs at least one vowel!'

  },

  syllables:{

    title:'Language — Syllables',

    outcomes:['Blend a consonant with each of the 5 vowels to form open syllables (ba, be, bi, bo, bu)','Recognise common syllable families in spoken words','Clap and count syllables in familiar words'],

    inquiries:['What sound do you make when you put "b" and "a" together?','How many syllables are in "banana"? Clap it!','Which consonant family starts with the /m/ sound?'],

    tip:'💡 Tip: Clap each syllable — ba-na-na = 3 claps, ap-ple = 2 claps!'

  },

  fib:{

    title:'Language — Fill in the Blank',

    outcomes:['Identify the missing vowel in a CVC (consonant-vowel-consonant) word','Apply phonics knowledge to decode simple words','Self-correct using letter-sound knowledge and picture clues'],

    inquiries:['What letter is missing from c_t?','Which vowel makes this word sound right?','Can you think of another word with the same middle sound?'],

    tip:'💡 Tip: Try saying each vowel out loud until the word sounds right — then you\'ll know!'

  },

  numbers:{

    title:'Mathematics — Numbers',

    outcomes:['Rote-count from 1 to 20 (PP1/PP2) or 1 to 100 (Grade 1)','Count concrete objects with one-to-one correspondence','Recognise numeral symbols and match them to quantities'],

    inquiries:['What number comes after 7? What comes before 10?','How many fingers do you have on both hands? Count them!','Can you find the number 5 somewhere in this room?'],

    tip:'💡 Tip: Count real objects — bottle tops, stones, beans. Touching each one as you count helps!'

  },

  shapes:{

    title:'Mathematics — Shapes',

    outcomes:['Name and describe basic 2D shapes: circle, square, triangle, rectangle, oval','Count the sides and corners of each shape','Identify shapes in the real environment (window = rectangle, clock = circle)'],

    inquiries:['How many sides does a triangle have?','Can you find something round (circle-shaped) in this room?','What is the difference between a square and a rectangle?'],

    tip:'💡 Tip: Go on a shape hunt around your home — find 3 different shapes!'

  },

  multiplication:{

    title:'Mathematics — Multiplication Tables',

    outcomes:['Recite multiplication tables from ×2 to ×10 fluently','Understand multiplication as repeated addition (3×4 = 4+4+4)','Apply multiplication facts to solve simple word problems'],

    inquiries:['What is 3 × 4? Can you show it with groups of objects?','If each hand has 5 fingers, how many fingers on 4 hands?','What multiplication fact can you see on a carton of 6 eggs?'],

    tip:'💡 Tip: 3 × 4 means "3 groups of 4". Draw dots to help you see it!'

  },

  animals:{

    title:'Environmental — Animals',

    outcomes:['Name and classify wild and domestic animals','Describe characteristics: sound made, habitat, physical features','Explain the uses of domestic animals to people'],

    inquiries:['What sound does a lion make? Where does it live?','Which of these animals do we find at home or on a farm?','How is a cow useful to us? What about a dog?'],

    tip:'💡 Tip: Visit a farm or watch a nature video to learn animal sounds and habits!'

  },

  body:{

    title:'Environmental — Body Parts',

    outcomes:['Name at least 10 external body parts','Describe the function of each body part','Understand why keeping the body clean is important'],

    inquiries:['What do you use your eyes for? Your ears? Your hands?','Point to your elbow — your knee — your ankle.','Why is it important to wash your hands after using the toilet?'],

    tip:'💡 Tip: Play "Simon says… touch your nose / your ear / your knee" to learn body parts!'

  },

  weather:{

    title:'Environmental — Weather',

    outcomes:['Describe the day\'s weather using correct vocabulary','Match appropriate clothing to each weather condition','Observe and record daily weather patterns on a chart'],

    inquiries:['How is the weather today? How do you know?','What would you wear if it were very cold? Very hot?','What happens to trees and grass when it is windy?'],

    tip:'💡 Tip: Keep a weather diary for one week — draw a sun, cloud, or raindrop each day!'

  },

  plants:{

    title:'Environmental — Plants',

    outcomes:['Name common plants in the local environment','Describe parts of a plant: roots, stem, leaves, flower, fruit','Understand that plants need water, sunlight and soil to grow'],

    inquiries:['What plants can you see around our school?','What do plants need to grow strong?','Which plants give us food? Which ones give us shade?'],

    tip:'💡 Tip: Plant a seed (like a bean) in a cup of soil. Water it and watch it grow!'

  },

  health:{

    title:'Environmental — Health, Hygiene & Safety',

    outcomes:['Demonstrate the 5 steps of proper handwashing','Classify foods as everyday (healthy) or sometimes (less healthy) foods','Identify potential dangers and practise simple safety responses'],

    inquiries:['When must we wash our hands? Name at least 4 times.','Which foods help you grow strong?','What should you do if you find a sharp blade on the floor?'],

    tip:'💡 Tip: Wash your hands for as long as it takes to sing "Happy Birthday" twice — that\'s 20 seconds!'

  },

  creation:{

    title:'Religious Education — God\'s Creation',

    outcomes:['Recognise that God created the world and everything in it (Genesis 1)','Express wonder and gratitude for the beauty of creation','Understand that God made each person special and loves them'],

    inquiries:['Who created you? Who created the sun, moon and stars?','What is your favourite part of God\'s creation?','The Bible says God looked at everything He made and said it was "very good." What does that mean to you?'],

    tip:'💡 Tip: Go outside and name 5 beautiful things God created that you can see right now!'

  },

  bible:{

    title:'Religious Education — Bible Stories',

    outcomes:['Retell key OT stories: Noah\'s Ark, David & Goliath, Daniel in the Lions\' Den','Identify the main moral lesson from each story','Apply Bible values (obedience, courage, faith) to daily life'],

    inquiries:['What did God tell Noah to build? Why did He do that?','How did David defeat Goliath? What lesson do we learn?','What happened to Daniel when he was thrown to the lions? Why?'],

    tip:'💡 Tip: Act out the stories with friends or family — it helps you remember them!'

  },

}



