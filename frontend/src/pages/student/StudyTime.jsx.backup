              style={{...card({cursor:'pointer',textAlign:'center',padding:'14px',

                border:`2px solid ${isSel?'#22c55e':'#1f2937'}`,

                background:isSel?'rgba(34,197,94,0.1)':'#1a2234',transition:'all .15s'})}}>

              <div style={{fontSize:'2rem',marginBottom:'6px'}}>{b.e}</div>

              <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.85rem'}}>{b.n}</div>

              <div style={{color:'#5eead4',fontSize:'.72rem'}}>{b.k}</div>

            </div>

          )

        })}

      </div>

      {sel&&(

        <div style={{...card({marginTop:'14px',background:'rgba(34,197,94,0.08)',border:'1px solid rgba(34,197,94,0.25)',

          display:'flex',gap:'16px',alignItems:'center',padding:'16px',flexWrap:'wrap'})}}>

          <span style={{fontSize:'3rem'}}>{sel.e}</span>

          <div>

            <div style={{fontSize:'1.2rem',fontWeight:800,color:'#f9fafb'}}>{sel.n} — <span style={{color:'#5eead4'}}>{sel.k}</span></div>

            <div style={{color:'#86efac',fontSize:'.9rem',marginTop:'4px'}}>Function: {sel.f}</div>

          </div>

        </div>

      )}

    </div>

  )

}



