            <div style={{fontSize:'2.2rem',marginBottom:'6px'}}>{w.e}</div>

            <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.85rem'}}>{w.n}</div>

            <div style={{color:'#5eead4',fontSize:'.7rem',marginBottom:'4px'}}>{w.k}</div>

            <div style={{color:'#9ca3af',fontSize:'.68rem'}}>{w.j}</div>

