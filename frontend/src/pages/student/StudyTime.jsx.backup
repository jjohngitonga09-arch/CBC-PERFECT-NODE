const card  = (extra={})=>({background:'#1a2234',border:'1px solid #1f2937',borderRadius:'14px',padding:'16px',...extra})

const badge = (col,extra={})=>({background:col+'20',border:`1px solid ${col}40`,borderRadius:'20px',padding:'3px 10px',fontSize:'.72rem',fontWeight:700,color:col,...extra})

const grid  = (min='140px',gap='10px')=>({display:'grid',gridTemplateColumns:`repeat(auto-fill,minmax(${min},1fr))`,gap})

const sectionTitle = (color)=>({fontSize:'1rem',fontWeight:800,color,margin:'0 0 14px',letterSpacing:'-0.2px'})

const label = {fontSize:'.7rem',fontWeight:700,color:'#6b7280',textTransform:'uppercase',letterSpacing:'.5px'}



