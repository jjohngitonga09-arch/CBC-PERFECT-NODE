function ShapeSvg({type,color='#6366f1',size=60}){

  const s={width:size,height:size}

  switch(type){

    case'circle':   return <svg {...s} viewBox="0 0 100 100"><circle cx="50" cy="50" r="44" fill={color} opacity=".85"/></svg>

    case'square':   return <svg {...s} viewBox="0 0 100 100"><rect x="6" y="6" width="88" height="88" rx="4" fill={color} opacity=".85"/></svg>

    case'triangle': return <svg {...s} viewBox="0 0 100 100"><polygon points="50,4 96,94 4,94" fill={color} opacity=".85"/></svg>

    case'rect':     return <svg width={size*1.6} height={size} viewBox="0 0 160 100"><rect x="5" y="10" width="150" height="80" rx="4" fill={color} opacity=".85"/></svg>

    case'oval':     return <svg width={size*1.4} height={size} viewBox="0 0 140 100"><ellipse cx="70" cy="50" rx="65" ry="44" fill={color} opacity=".85"/></svg>

    case'diamond':  return <svg {...s} viewBox="0 0 100 100"><polygon points="50,4 96,50 50,96 4,50" fill={color} opacity=".85"/></svg>

    default:        return null

  }

}



