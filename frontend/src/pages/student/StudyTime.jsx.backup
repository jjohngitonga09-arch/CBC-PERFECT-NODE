}



/* ── HEALTH & SAFETY ── */

function HealthSafetySection(){

  const [tab,setTab]=useState(0)

  const h=HEALTH_SAFETY[tab]

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Health, Hygiene & Safety — Afya na Usalama</p>

      <div style={{display:'flex',gap:'8px',flexWrap:'wrap',marginBottom:'16px'}}>

        {HEALTH_SAFETY.map((h,i)=>(

          <button key={i} onClick={()=>setTab(i)}

            style={{padding:'8px 14px',borderRadius:'20px',border:`1px solid ${tab===i?'#22c55e':'#374151'}`,

              background:tab===i?'rgba(34,197,94,0.15)':'transparent',

              color:tab===i?'#86efac':'#9ca3af',fontWeight:700,fontSize:'.8rem',cursor:'pointer'}}>

            {h.e} {h.t}

          </button>

        ))}

      </div>

      <div style={{...card({background:'rgba(34,197,94,0.06)',border:'1px solid rgba(34,197,94,0.2)',padding:'20px'})}}>

        <p style={{fontWeight:800,color:'#f9fafb',fontSize:'1.1rem',margin:'0 0 12px'}}>{h.e} {h.t}</p>

        {h.steps&&(

          <>

            <p style={{...label,color:'#86efac',marginBottom:'8px'}}>Steps:</p>

            {h.steps.map((s,i)=>(

              <div key={i} style={{display:'flex',gap:'10px',alignItems:'flex-start',marginBottom:'8px'}}>

                <span style={{...badge('#22c55e',{flexShrink:0}),padding:'2px 8px'}}>{i+1}</span>

                <span style={{color:'#d1fae5',fontSize:'.9rem'}}>{s}</span>

              </div>

            ))}

            <p style={{...label,color:'#86efac',marginTop:'12px',marginBottom:'6px'}}>When to wash hands:</p>

            <div style={{display:'flex',flexWrap:'wrap',gap:'6px'}}>

              {h.when.map(w=><span key={w} style={{...badge('#22c55e',{fontSize:'.78rem'})}}>{w}</span>)}

            </div>

          </>

        )}

        {h.groups&&(

          <>

            <p style={{...label,color:'#86efac',marginBottom:'8px'}}>Food Groups:</p>

            {h.groups.map(g=><div key={g} style={{color:'#d1fae5',fontSize:'.9rem',marginBottom:'4px'}}>• {g}</div>)}

            <div style={{...badge('#22c55e',{display:'inline-block',marginTop:'8px',fontSize:'.8rem'})}}>{h.rule}</div>

          </>

        )}

        {h.rules&&(

          <>

            <p style={{...label,color:'#86efac',marginBottom:'8px'}}>Safety Rules — Sheria za Usalama:</p>

            {h.rules.map((r,i)=>(

              <div key={i} style={{display:'flex',gap:'10px',marginBottom:'8px'}}>

                <span style={{color:'#f87171',flexShrink:0}}>⚠️</span>

                <span style={{color:'#fecaca',fontSize:'.9rem'}}>{r}</span>

              </div>

            ))}

          </>

        )}

        {h.daily&&(

          <>

            <p style={{...label,color:'#86efac',marginBottom:'8px'}}>Daily Hygiene Habits:</p>

            {h.daily.map(d=><div key={d} style={{color:'#d1fae5',fontSize:'.9rem',marginBottom:'4px'}}>✅ {d}</div>)}

            <div style={{marginTop:'10px',padding:'8px 12px',background:'rgba(239,68,68,0.08)',borderRadius:'8px',border:'1px solid rgba(239,68,68,0.2)'}}>

              <span style={{color:'#fca5a5',fontSize:'.8rem'}}>🚫 Never share: {h.shared?.replace('Never share: ','')}</span>

            </div>

          </>

        )}

      </div>

    </div>

  )

}



