      <div style={{...card({marginTop:'14px',background:'rgba(34,197,94,0.06)',border:'1px solid rgba(34,197,94,0.2)',padding:'14px'})}}>

        <p style={{...label,color:'#86efac',marginBottom:'8px'}}>📊 Class Weather Chart — Record today's weather!</p>

        <div style={{display:'flex',gap:'8px',flexWrap:'wrap'}}>

          {WEATHER.map(w=>(

            <div key={w.n} style={{textAlign:'center',padding:'8px 10px',borderRadius:'10px',background:'#111827',border:'1px solid #1f2937'}}>

              <div style={{fontSize:'1.5rem'}}>{w.e}</div>

              <div style={{fontSize:'.65rem',color:'#6b7280'}}>{w.n}</div>

