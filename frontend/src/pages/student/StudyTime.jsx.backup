            <span style={{fontSize:'2.5rem'}}>{sel.e}</span>

            <div>

              <div style={{fontWeight:800,color:'#f9fafb',fontSize:'1.1rem'}}>{sel.n} — {sel.k}</div>

              <div style={{color:'#93c5fd',fontSize:'.9rem',margin:'4px 0'}}>{sel.d}</div>

              <div style={{color:'#9ca3af',fontSize:'.8rem'}}>What to wear: <span style={{fontSize:'1.2rem'}}>{sel.wear}</span></div>

            </div>

