/* ── LETTER CHART ── */

function LetterChart({upper,showKiswahili}){

  const [sel,setSel]=useState(null)

  const letters=upper?ALPHABET:ALPHABET.map(l=>l.toLowerCase())

  const getKey=l=>l.toUpperCase()

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>{upper?'Uppercase — CAPITAL LETTERS':'Lowercase — small letters'}</p>

      <div style={grid('88px','10px')}>

        {letters.map(l=>{

          const k=getKey(l); const isVowel=VOWELS.includes(k); const isSel=sel===k

          return(

            <div key={l} onClick={()=>setSel(isSel?null:k)}

              style={{...card({padding:'10px 6px',textAlign:'center',cursor:'pointer',

                background:isSel?'rgba(99,102,241,0.2)':'#1a2234',

                border:`2px solid ${isSel?'#6366f1':isVowel?'rgba(239,68,68,0.4)':'#1f2937'}`,

                transition:'all .15s'})}}

            >

              <div style={{fontSize:'3.2rem',fontWeight:900,color:isVowel?'#f87171':'#f9fafb',lineHeight:1.1}}>{l}</div>

              <div style={{fontSize:'.78rem',color:'#9ca3af',marginTop:'5px'}}>{LETTERS[k].s}</div>

            </div>

          )

        })}

      </div>

      {sel&&(

        <div style={{...card({background:'rgba(99,102,241,0.1)',border:'1px solid rgba(99,102,241,0.3)',marginTop:'16px',display:'flex',alignItems:'center',gap:'20px',flexWrap:'wrap'})}}>

          <div style={{fontSize:'5rem',lineHeight:1}}>{LETTERS[sel].e}</div>

          <div style={{flex:1}}>

            <div style={{fontSize:'3rem',fontWeight:900,color:'#f9fafb',lineHeight:1}}>{upper?sel:sel.toLowerCase()}</div>

            <div style={{fontSize:'1.1rem',fontWeight:700,color:'#a5b4fc',margin:'4px 0'}}>{LETTERS[sel].w}</div>

            <div style={{fontSize:'.8rem',color:'#6b7280'}}>Sound: <span style={{color:'#c4b5fd'}}>{LETTERS[sel].s}</span></div>

            {showKiswahili&&<div style={{fontSize:'.8rem',color:'#6b7280',marginTop:'2px'}}>Kiswahili: <span style={{color:'#5eead4'}}>{LETTERS[sel].k}</span></div>}

            <div style={{...badge(VOWELS.includes(sel)?'#ef4444':'#3b82f6',{marginTop:'8px',display:'inline-block'})}}>

              {VOWELS.includes(sel)?'VOWEL — Irabu':'CONSONANT — Konsonanti'}

            </div>

          </div>

        </div>

      )}

      <div style={{marginTop:'12px',padding:'10px 14px',background:'rgba(239,68,68,0.08)',borderRadius:'10px',border:'1px solid rgba(239,68,68,0.2)'}}>

        <span style={{...label,color:'#fca5a5'}}>🔴 Red letters = Vowels (Irabu) → </span>

        <span style={{fontWeight:700,color:'#f87171',fontSize:'.9rem'}}>A  E  I  O  U</span>

        <span style={{...label,color:'#9ca3af',marginLeft:'12px'}}> · Blue letters = Consonants (Konsonanti)</span>

      </div>

    </div>

  )

}



/* ── VOWELS & CONSONANTS ── */

function VowelsConsonants(){

  const [sel,setSel]=useState(null)

  const vowelWords={A:'Apple 🍎',E:'Egg 🥚',I:'Insect 🐛',O:'Orange 🍊',U:'Umbrella ☂️'}

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Vowels (Irabu) & Consonants (Konsonanti)</p>

      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'16px',marginBottom:'16px'}}>

        <div style={{...card({background:'rgba(239,68,68,0.08)',border:'1px solid rgba(239,68,68,0.25)'})}}>

          <p style={{...sectionTitle('#f87171'),fontSize:'.85rem'}}>Vowels — Irabu (5)</p>

          {VOWELS.map(v=>(

            <div key={v} onClick={()=>setSel(sel===v?null:v)}

              style={{display:'flex',alignItems:'center',gap:'10px',padding:'8px',borderRadius:'8px',

                background:sel===v?'rgba(239,68,68,0.15)':'transparent',cursor:'pointer',marginBottom:'4px'}}>

              <span style={{fontSize:'1.5rem',fontWeight:900,color:'#f87171',width:'28px'}}>{v}</span>

              <span style={{fontSize:'.8rem',color:'#9ca3af'}}>{vowelWords[v]}</span>

            </div>

          ))}

        </div>

        <div style={{...card({background:'rgba(59,130,246,0.08)',border:'1px solid rgba(59,130,246,0.25)'})}}>

          <p style={{...sectionTitle('#60a5fa'),fontSize:'.85rem'}}>Consonants — Konsonanti (21)</p>

          <div style={{display:'flex',flexWrap:'wrap',gap:'6px'}}>

            {'BCDFGHJKLMNPQRSTVWXYZ'.split('').map(c=>(

              <span key={c} onClick={()=>setSel(sel===c?null:c)}

                style={{...badge('#3b82f6',{cursor:'pointer',fontSize:'.85rem',padding:'4px 8px',

                  background:sel===c?'rgba(59,130,246,0.25)':'rgba(59,130,246,0.1)'})}}>

                {c}

              </span>

            ))}

          </div>

        </div>

      </div>

      {sel&&(

        <div style={{...card({background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.25)',display:'flex',gap:'16px',alignItems:'center',flexWrap:'wrap'})}}>

          <div style={{fontSize:'4rem'}}>{LETTERS[sel]?.e||'🔤'}</div>

          <div>

            <div style={{fontSize:'2.5rem',fontWeight:900,color:'#f9fafb'}}>{sel}</div>

            <div style={{color:'#a5b4fc',fontSize:'.9rem',fontWeight:600}}>{LETTERS[sel]?.w} · {LETTERS[sel]?.s}</div>

            <div style={{color:'#5eead4',fontSize:'.8rem',marginTop:'2px'}}>Kiswahili: {LETTERS[sel]?.k}</div>

            <div style={{...badge(VOWELS.includes(sel)?'#ef4444':'#3b82f6',{marginTop:'6px',display:'inline-block'})}}>

              {VOWELS.includes(sel)?'VOWEL — Irabu':'CONSONANT — Konsonanti'}

            </div>

          </div>

        </div>

      )}

    </div>

  )

}



/* ── SYLLABLES ── */

function SyllableChart(){

  const [family,setFamily]=useState('b')

  const [hilight,setHilight]=useState(null)

  const families=Object.keys(SYLLABLE_FAMILIES)

  const sylls=SYLLABLE_FAMILIES[family]

  const vowelColors={'a':'#ef4444','e':'#f97316','i':'#eab308','o':'#22c55e','u':'#3b82f6',"'a":'#ef4444',"'e":'#f97316',"'i":'#eab308',"'o":'#22c55e',"'u":'#3b82f6'}

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Syllable Families</p>

      <div style={{marginBottom:'16px'}}>

        <p style={{...label,marginBottom:'8px'}}>Choose a consonant family:</p>

        <div style={{display:'flex',flexWrap:'wrap',gap:'6px'}}>

          {families.map(f=>(

            <button key={f} onClick={()=>{setFamily(f);setHilight(null)}}

              style={{padding:'6px 12px',borderRadius:'20px',border:`1px solid ${family===f?'#6366f1':'#374151'}`,

                background:family===f?'rgba(99,102,241,0.2)':'transparent',

                color:family===f?'#a5b4fc':'#9ca3af',fontWeight:700,fontSize:'.85rem',cursor:'pointer'}}>

              {f}–

            </button>

          ))}

        </div>

      </div>

      <div style={{...card({background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.25)',marginBottom:'16px'})}}>

        <p style={{...label,marginBottom:'10px',color:'#a5b4fc'}}>Click each syllable to highlight it:</p>

        <div style={{display:'flex',gap:'10px',flexWrap:'wrap',justifyContent:'center'}}>

          {sylls.map(s=>{

            const vow=s.slice(family.length)

            const col=vowelColors[vow]||'#9ca3af'

            const isSel=hilight===s

            return(

              <div key={s} onClick={()=>setHilight(isSel?null:s)}

                style={{padding:'16px 20px',borderRadius:'14px',textAlign:'center',cursor:'pointer',minWidth:'80px',

                  border:`2px solid ${isSel?col:'#374151'}`,background:isSel?col+'25':'#111827',transition:'all .15s'}}>

                <span style={{fontSize:'3.2rem',fontWeight:900,color:isSel?col:'#f9fafb',letterSpacing:'-1px'}}>

                  <span style={{color:isSel?'#f9fafb':'#9ca3af'}}>{family}</span>

                  <span style={{color:col}}>{vow}</span>

                </span>

              </div>

            )

          })}

        </div>

        {hilight&&(

          <div style={{marginTop:'12px',textAlign:'center',padding:'8px',background:'rgba(99,102,241,0.12)',borderRadius:'8px'}}>

            <span style={{color:'#a5b4fc',fontSize:'.9rem'}}>You selected: </span>

            <span style={{fontSize:'1.4rem',fontWeight:900,color:'#f9fafb',marginLeft:'6px'}}>{hilight}</span>

          </div>

        )}

      </div>

      <div style={{overflowX:'auto'}}>

        <table style={{width:'100%',borderCollapse:'collapse',fontSize:'.85rem'}}>

          <thead>

            <tr>

              <th style={{padding:'8px',color:'#6b7280',textAlign:'left',borderBottom:'1px solid #1f2937'}}>Family</th>

              {['a','e','i','o','u'].map(v=>(

                <th key={v} style={{padding:'8px',textAlign:'center',borderBottom:'1px solid #1f2937',

                  color:vowelColors[v],fontWeight:800,fontSize:'1rem'}}>–{v}</th>

              ))}

            </tr>

          </thead>

          <tbody>

            {families.map(f=>(

              <tr key={f} style={{background:f===family?'rgba(99,102,241,0.08)':'transparent'}}>

                <td style={{padding:'8px',color:'#9ca3af',fontWeight:700,borderBottom:'1px solid #111827'}}>{f}–</td>

                {SYLLABLE_FAMILIES[f].map((s,i)=>{

                  const v=['a','e','i','o','u'][i]

                  return(

                    <td key={s} style={{padding:'8px',textAlign:'center',borderBottom:'1px solid #111827',

                      fontWeight:800,fontSize:'1.4rem',color:vowelColors[v],cursor:'pointer'}}

                      onClick={()=>{setFamily(f);setHilight(s)}}>

                      {s}

                    </td>

                  )

                })}

              </tr>

            ))}

          </tbody>

        </table>

      </div>

    </div>

  )

}



/* ── FILL IN THE BLANK ── */

function FillInBlank({level}){

  const words=FIB[level]||FIB.PP1

  const [idx,setIdx]=useState(0)

  const [ans,setAns]=useState(null)

  const [chosen,setChosen]=useState(null)

  const [score,setScore]=useState(0)

  const [total,setTotal]=useState(0)

  const w=words[idx]

  const handleAnswer=(opt)=>{

    if(ans)return

    const correct=opt===w.m

    setChosen(opt);setAns(correct?'correct':'wrong')

    setTotal(t=>t+1)

    if(correct)setScore(s=>s+1)

    setTimeout(()=>{

      setAns(null);setChosen(null)

      setIdx(i=>(i+1)%words.length)

    },1500)

  }

  // Render blank pattern: each consecutive run of _ = one gap bar
  const renderBlankWord = (pattern) => {
    const segs = []
    let i = 0
    while (i < pattern.length) {
      if (pattern[i] === '_') {
        let count = 0
        while (i < pattern.length && pattern[i] === '_') { count++; i++ }
        segs.push({ type:'blank', count })
      } else {
        let txt = ''
        while (i < pattern.length && pattern[i] !== '_') { txt += pattern[i]; i++ }
        segs.push({ type:'text', txt })
      }
    }
    return segs.map((seg, idx) =>
      seg.type === 'text'
        ? <span key={idx} style={{color:'#f9fafb',fontSize:'3.2rem',fontWeight:900,fontFamily:'monospace',letterSpacing:'4px'}}>{seg.txt}</span>
        : <span key={idx} style={{
            display:'inline-block',
            width: seg.count === 1 ? '56px' : '100px',
            height:'8px',
            borderRadius:'4px',
            background:'#6366f1',
            margin:'0 8px',
            verticalAlign:'middle',
            position:'relative',
            top:'-6px'
          }}/>
    )
  }

  return(

    <div>

      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'16px',flexWrap:'wrap',gap:'10px'}}>

        <p style={sectionTitle('#f9fafb')}>Fill in the Missing Letter</p>

        <div style={{display:'flex',gap:'8px'}}>

          <span style={{...badge('#22c55e')}}>{score} ✅</span>

          <span style={{...badge('#6b7280')}}>{idx+1} / {words.length}</span>

          <button onClick={()=>{setIdx(0);setScore(0);setTotal(0);setAns(null);setChosen(null)}}

            style={{...badge('#f97316',{cursor:'pointer'})}}>↺ Restart</button>

        </div>

      </div>

      <div style={{...card({textAlign:'center',padding:'32px 20px',marginBottom:'16px',

        background:ans==='correct'?'rgba(34,197,94,0.1)':ans==='wrong'?'rgba(239,68,68,0.1)':'rgba(99,102,241,0.06)',

        border:`2px solid ${ans==='correct'?'#22c55e':ans==='wrong'?'#ef4444':'rgba(99,102,241,0.2)'}`,

        transition:'all .2s'})}}>

        <div style={{fontSize:'4rem',marginBottom:'12px'}}>{w.e}</div>

        <div style={{fontSize:'2.8rem',fontWeight:900,color:'#f9fafb',letterSpacing:'8px',marginBottom:'8px',fontFamily:'monospace'}}>

          {blankDisplay}

        </div>

        {ans==='correct'&&<div style={{color:'#4ade80',fontWeight:700,fontSize:'1.1rem',marginTop:'8px'}}>⭐ Correct! The word is "{w.w}"</div>}

        {ans==='wrong'&&<div style={{color:'#f87171',fontWeight:700,fontSize:'1.1rem',marginTop:'8px'}}>Not quite! The answer is "{w.m}"</div>}

      </div>

      <div style={{display:'flex',gap:'10px',justifyContent:'center',flexWrap:'wrap'}}>

        {w.o.map(opt=>(

          <button key={opt} onClick={()=>handleAnswer(opt)} disabled={!!ans}

            style={{padding:'18px 28px',borderRadius:'14px',fontWeight:900,fontSize:'1.6rem',cursor:ans?'default':'pointer',

              border:`2px solid ${chosen===opt?(ans==='correct'?'#22c55e':'#ef4444'):'#374151'}`,

              background:chosen===opt?(ans==='correct'?'rgba(34,197,94,0.2)':'rgba(239,68,68,0.2)'):'#1a2234',

              color:chosen===opt?(ans==='correct'?'#4ade80':'#f87171'):'#f9fafb',

              transition:'all .1s',transform:chosen===opt&&ans?'scale(1.1)':'scale(1)'}}>

            {opt}

          </button>

        ))}

      </div>

      {total>0&&<div style={{textAlign:'center',marginTop:'14px',color:'#6b7280',fontSize:'.8rem'}}>

        Score: {score}/{total} · {Math.round(score/total*100)}%

      </div>}

    </div>

  )

}



/* ── NUMBER CHART ── */

function NumberChart({max=20}){

  const [sel,setSel]=useState(null)

  const nums=Array.from({length:max},(_,i)=>i+1)

  const dots=(n)=>{

    const arr=Array.from({length:Math.min(n,10)},(_,i)=>i)

    return arr.map(i=>(

      <span key={i} style={{display:'inline-block',width:'13px',height:'13px',borderRadius:'50%',

        background:'#6366f1',margin:'2px',opacity:.9}}/>

    ))

  }

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Numbers 1 – {max}</p>

      <div style={grid('92px','10px')}>

        {nums.map(n=>(

          <div key={n} onClick={()=>setSel(sel===n?null:n)}

            style={{...card({padding:'10px 6px',textAlign:'center',cursor:'pointer',

              background:sel===n?'rgba(139,92,246,0.2)':'#1a2234',

              border:`2px solid ${sel===n?'#8b5cf6':'#1f2937'}`,transition:'all .15s'})}}>

            <div style={{fontSize:'2.7rem',fontWeight:900,color:sel===n?'#c4b5fd':'#f9fafb'}}>{n}</div>

            <div style={{display:'flex',flexWrap:'wrap',justifyContent:'center',gap:'3px',marginTop:'6px',minHeight:'36px'}}>

              {dots(n)}

            </div>

          </div>

        ))}

      </div>

      {sel&&(

        <div style={{...card({background:'rgba(139,92,246,0.1)',border:'1px solid rgba(139,92,246,0.3)',marginTop:'16px',textAlign:'center',padding:'24px'})}}>

          <div style={{fontSize:'5rem',fontWeight:900,color:'#c4b5fd',lineHeight:1}}>{sel}</div>

          <div style={{display:'flex',flexWrap:'wrap',justifyContent:'center',gap:'4px',margin:'12px 0'}}>

            {Array.from({length:sel}).map((_,i)=>(

              <span key={i} style={{fontSize:'1.4rem'}}>⭐</span>

            ))}

          </div>

          <div style={{color:'#9ca3af',fontSize:'.85rem'}}>

            {sel-1} + 1 = <strong style={{color:'#c4b5fd'}}>{sel}</strong>

            &nbsp;&nbsp;·&nbsp;&nbsp;

            {sel} - 1 = <strong style={{color:'#c4b5fd'}}>{sel-1}</strong>

          </div>

        </div>

      )}

    </div>

  )

}



/* ── ADDITION / SUBTRACTION PRACTICE ── */

function ArithmeticPractice({op}){

  const gen=()=>{

    const a=Math.floor(Math.random()*10)+1

    const b=op==='+'?Math.floor(Math.random()*10)+1:Math.floor(Math.random()*a)+1

    return{a,b,ans:op==='+'?a+b:a-b}

  }

  const [q,setQ]=useState(gen)

  const [input,setInput]=useState('')

  const [result,setResult]=useState(null)

  const [score,setScore]=useState(0)

  const [total,setTotal]=useState(0)

  const check=()=>{

    if(input==='')return

    const correct=parseInt(input)===q.ans

    setResult(correct?'correct':'wrong')

    setTotal(t=>t+1)

    if(correct)setScore(s=>s+1)

    setTimeout(()=>{setQ(gen());setInput('');setResult(null)},1200)

  }

  return(

    <div>

      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'16px'}}>

        <p style={sectionTitle('#f9fafb')}>{op==='+'?'Addition — Kuongeza':'Subtraction — Kutoa'}</p>

        <span style={{...badge('#22c55e')}}>{score}/{total}</span>

      </div>

      <div style={{...card({textAlign:'center',padding:'40px 20px',marginBottom:'16px',

        background:result==='correct'?'rgba(34,197,94,0.1)':result==='wrong'?'rgba(239,68,68,0.1)':'rgba(99,102,241,0.06)',

        border:`2px solid ${result==='correct'?'#22c55e':result==='wrong'?'#ef4444':'#1f2937'}`})}}>

        <div style={{fontSize:'3rem',fontWeight:900,color:'#f9fafb',letterSpacing:'4px'}}>

          {q.a} {op} {q.b} = ?

        </div>

        {result==='correct'&&<div style={{color:'#4ade80',fontWeight:700,marginTop:'8px'}}>⭐ Correct! = {q.ans}</div>}

        {result==='wrong'&&<div style={{color:'#f87171',fontWeight:700,marginTop:'8px'}}>Answer is {q.ans}</div>}

      </div>

      <div style={{display:'flex',gap:'10px',justifyContent:'center'}}>

        <input type="number" value={input} onChange={e=>setInput(e.target.value)}

          onKeyDown={e=>e.key==='Enter'&&check()}

          placeholder="Your answer"

          style={{padding:'12px 18px',borderRadius:'10px',border:'1px solid #374151',background:'#111827',

            color:'#f9fafb',fontSize:'1.2rem',fontWeight:700,width:'140px',textAlign:'center',outline:'none'}}/>

        <button onClick={check}

          style={{padding:'12px 24px',borderRadius:'10px',background:'linear-gradient(135deg,#6366f1,#4f46e5)',

            color:'#fff',fontWeight:700,border:'none',cursor:'pointer',fontSize:'1rem'}}>

          Check ✓

        </button>

      </div>

      <p style={{textAlign:'center',color:'#6b7280',fontSize:'.75rem',marginTop:'10px'}}>Press Enter or click Check</p>

    </div>

  )

}



/* ── MULTIPLICATION TABLES ── */

function MultiplicationTables(){
  const nums = Array.from({length:13},(_,i)=>i+1)
  const [highlight,setHighlight] = useState(null)

  const getCellColor = (r,c) => {
    if(!highlight) return null
    if(r===highlight.r && c===highlight.c) return 'rgba(99,102,241,0.6)'
    if(r===highlight.r || c===highlight.c) return 'rgba(99,102,241,0.12)'
    return null
  }

  return(
    <div>
      <p style={{fontSize:'1rem',fontWeight:800,color:'#f9fafb',margin:'0 0 4px'}}>Multiplication Tables — 1 to 13</p>
      <p style={{fontSize:'.78rem',color:'#6b7280',margin:'0 0 16px'}}>Tap any cell to highlight its row and column</p>
      <div style={{overflowX:'auto'}}>
        <table style={{borderCollapse:'collapse',fontSize:'.82rem',minWidth:'100%'}}>
          <thead>
            <tr>
              <th style={{padding:'8px 10px',background:'#0d1117',color:'#6b7280',fontWeight:700,border:'1px solid #1f2937',position:'sticky',left:0,zIndex:2}}>—</th>
              {nums.map(n=>(
                <th key={n} style={{padding:'8px 10px',background:'#111827',color:'#a5b4fc',fontWeight:800,border:'1px solid #1f2937',textAlign:'center',minWidth:'44px'}}>
                  {n}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {nums.map(r=>(
              <tr key={r}>
                <td style={{padding:'8px 10px',background:'#111827',color:'#a5b4fc',fontWeight:800,border:'1px solid #1f2937',textAlign:'center',position:'sticky',left:0,zIndex:1}}>
                  {r}
                </td>
                {nums.map(c=>{
                  const val = r*c
                  const bg = getCellColor(r,c)
                  const isSelected = highlight?.r===r && highlight?.c===c
                  return(
                    <td key={c}
                      onClick={()=>setHighlight(highlight?.r===r&&highlight?.c===c?null:{r,c})}
                      style={{
                        padding:'8px 10px',textAlign:'center',border:'1px solid #1f2937',
                        background: bg || (r%2===0?'#0f1520':'#0a0e17'),
                        color: isSelected?'#fff':bg?'#c4b5fd':'#e5e7eb',
                        fontWeight: isSelected?900:bg?700:400,
                        fontSize: isSelected?'1rem':'.82rem',
                        cursor:'pointer',transition:'all .1s',
                        borderRadius: isSelected?'4px':'0'
                      }}>
                      {val}
                    </td>
                  )
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      {highlight&&(
        <div style={{marginTop:'14px',padding:'12px 16px',background:'rgba(99,102,241,0.1)',borderRadius:'10px',border:'1px solid rgba(99,102,241,0.25)',display:'flex',gap:'16px',alignItems:'center',flexWrap:'wrap'}}>
          <span style={{fontSize:'1.4rem',fontWeight:900,color:'#f9fafb'}}>{highlight.r} — {highlight.c} = <span style={{color:'#a5b4fc'}}>{highlight.r*highlight.c}</span></span>
          <span style={{color:'#6b7280',fontSize:'.82rem'}}>That is {highlight.r} groups of {highlight.c}</span>
          <button onClick={()=>setHighlight(null)} style={{marginLeft:'auto',padding:'4px 10px',borderRadius:'6px',background:'transparent',border:'1px solid #374151',color:'#6b7280',cursor:'pointer',fontSize:'.78rem'}}>Clear</button>
        </div>
      )}
    </div>
  )
}




/* ── SHAPES ── */

function ShapesSection(){

  const [sel,setSel]=useState(null)

  const shapeColors=['#6366f1','#3b82f6','#ef4444','#22c55e','#f97316','#a855f7']

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>2D Shapes — Maumbo</p>

      <div style={grid('170px','12px')}>

        {SHAPES.map((sh,i)=>{

          const col=shapeColors[i]

          const isSel=sel?.n===sh.n

          return(

            <div key={sh.n} onClick={()=>setSel(isSel?null:sh)}

              style={{...card({cursor:'pointer',textAlign:'center',padding:'20px 10px',

                border:`2px solid ${isSel?col:'#1f2937'}`,background:isSel?col+'15':'#1a2234',

                transition:'all .15s'})}}>

              <div style={{display:'flex',justifyContent:'center',marginBottom:'10px'}}>

                <ShapeSvg type={sh.svg} color={col} size={90}/>

              </div>

              <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.9rem'}}>{sh.n}</div>

              <div style={{color:'#5eead4',fontSize:'.75rem'}}>{sh.k}</div>

              {sh.sides>0&&<div style={{...badge(col,{marginTop:'6px',display:'inline-block'}),fontSize:'.65rem'}}>{sh.sides} sides</div>}

            </div>

          )

        })}

      </div>

      {sel&&(

        <div style={{...card({background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.25)',marginTop:'16px',

          display:'flex',gap:'20px',alignItems:'center',flexWrap:'wrap',padding:'20px'})}}>

          <ShapeSvg type={sel.svg} color='#6366f1' size={80}/>

          <div>

            <div style={{fontSize:'1.4rem',fontWeight:800,color:'#f9fafb',marginBottom:'4px'}}>{sel.n} — {sel.k}</div>

            <div style={{color:'#9ca3af',fontSize:'.9rem',marginBottom:'4px'}}>{sel.desc}</div>

            {sel.sides>0

              ?<div style={{color:'#a5b4fc',fontSize:'.85rem'}}>Sides: <strong>{sel.sides}</strong> · Corners: <strong>{sel.sides}</strong></div>

              :<div style={{color:'#a5b4fc',fontSize:'.85rem'}}>No sides, no corners — perfectly curved!</div>

            }

            <div style={{color:'#6b7280',fontSize:'.8rem',marginTop:'6px'}}>

              <strong>Find it around you:</strong>&nbsp;

              {{circle:'clock 🕐, coin, ball',square:'tile, button, window pane',triangle:'roof, piece of pizza, yield sign',

                rect:'door 🚪, book, phone',oval:'egg, mirror, leaf',diamond:'kite, road sign'}[sel.svg]}

            </div>

          </div>

        </div>

      )}

    </div>

  )

}



/* ── COLOURS ── */

