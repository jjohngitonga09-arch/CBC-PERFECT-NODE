          <div style={{display:'flex',gap:'8px',justifyContent:'center',flexWrap:'wrap',marginTop:'10px'}}>

            {sel.w.split('').map((l,i)=>(

              <span key={i} style={{width:'36px',height:'36px',borderRadius:'8px',display:'flex',alignItems:'center',justifyContent:'center',

                fontWeight:900,fontSize:'1.1rem',

                background:VOWELS.includes(l.toUpperCase())?'rgba(239,68,68,0.2)':'rgba(59,130,246,0.15)',

                border:`1px solid ${VOWELS.includes(l.toUpperCase())?'rgba(239,68,68,0.4)':'rgba(59,130,246,0.3)'}`,

                color:VOWELS.includes(l.toUpperCase())?'#f87171':'#93c5fd'}}>

                {l}

              </span>

            ))}

          </div>

        </div>

      )}

    </div>

  )

}



/* ── COUNTING FUN ── */

function CountingFun(){

  const [count,setCount]=useState(0)

  const [target]=useState(()=>Math.floor(Math.random()*15)+5)

  const done=count===target

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Counting Fun — Kuhesabu</p>

      <div style={{...card({textAlign:'center',padding:'32px 20px',

        background:done?'rgba(34,197,94,0.1)':'rgba(139,92,246,0.06)',

        border:`2px solid ${done?'#22c55e':'rgba(139,92,246,0.2)'}`,transition:'all .3s',marginBottom:'16px'})}}>

        {done?(

          <>

            <div style={{fontSize:'3rem',marginBottom:'8px'}}>🎉</div>

            <div style={{fontSize:'2rem',fontWeight:900,color:'#4ade80'}}>You reached {target}!</div>

            <div style={{color:'#86efac',marginTop:'6px'}}>Excellent counting! 🌟</div>

            <button onClick={()=>setCount(0)} style={{marginTop:'16px',padding:'10px 20px',borderRadius:'10px',

              background:'linear-gradient(135deg,#22c55e,#16a34a)',color:'#fff',border:'none',fontWeight:700,cursor:'pointer'}}>

              Count again ↺

            </button>

          </>

        ):(

          <>

            <div style={{fontSize:'5rem',fontWeight:900,color:'#c4b5fd',lineHeight:1,marginBottom:'8px'}}>{count}</div>

            <div style={{display:'flex',flexWrap:'wrap',justifyContent:'center',gap:'4px',marginBottom:'16px',minHeight:'60px'}}>

              {Array.from({length:count}).map((_,i)=>(

                <span key={i} style={{fontSize:'1.3rem'}}>⭐</span>

              ))}

            </div>

            <div style={{color:'#9ca3af',fontSize:'.85rem',marginBottom:'16px'}}>

              Count to <strong style={{color:'#f9fafb'}}>{target}</strong> · {target-count} more to go!

            </div>

            <div style={{display:'flex',gap:'10px',justifyContent:'center',flexWrap:'wrap'}}>

              <button onClick={()=>setCount(c=>Math.min(c+1,target))}

                style={{padding:'14px 28px',borderRadius:'12px',fontWeight:900,fontSize:'1.4rem',

                  background:'linear-gradient(135deg,#8b5cf6,#6d28d9)',color:'#fff',border:'none',cursor:'pointer'}}>

                + 1

              </button>

              <button onClick={()=>setCount(c=>Math.min(c+5,target))}

                style={{padding:'14px 28px',borderRadius:'12px',fontWeight:900,fontSize:'1.4rem',

                  background:'linear-gradient(135deg,#3b82f6,#2563eb)',color:'#fff',border:'none',cursor:'pointer'}}>

                + 5

              </button>

              <button onClick={()=>setCount(0)}

                style={{padding:'14px 20px',borderRadius:'12px',fontWeight:700,fontSize:'1rem',

                  background:'#1a2234',color:'#9ca3af',border:'1px solid #374151',cursor:'pointer'}}>

                Reset

              </button>

            </div>

          </>

        )}

      </div>

      <div style={grid('80px','6px')}>

        {Array.from({length:20},(_,i)=>i+1).map(n=>(

          <div key={n} style={{...card({padding:'8px',textAlign:'center',

            background:n<=count?'rgba(139,92,246,0.25)':'#1a2234',

            border:`1px solid ${n<=count?'#8b5cf6':'#1f2937'}`,transition:'all .15s'})}}>

            <span style={{fontWeight:700,color:n<=count?'#c4b5fd':'#9ca3af',fontSize:'.9rem'}}>{n}</span>

          </div>

        ))}

      </div>

    </div>

  )

}



/* ── MEASUREMENT ── */

function MeasurementSection(){

  const concepts=[

    {t:'Length — Urefu',e:'📏',pairs:[{big:'🐘 Elephant',small:'🐭 Mouse',label:'Longer / Shorter',k:'Ndefu / Fupi'}]},

    {t:'Weight — Uzito',e:'⚖️',pairs:[{big:'🪨 Rock',small:'🍃 Leaf',label:'Heavier / Lighter',k:'Nzito / Nyepesi'}]},

    {t:'Capacity — Ujazo',e:'🫙',pairs:[{big:'🪣 Bucket',small:'☕ Cup',label:'Holds More / Less',k:'Inashikilia zaidi / kidogo'}]},

    {t:'Size — Ukubwa',e:'📐',pairs:[{big:'🏫 School',small:'🏠 House',label:'Bigger / Smaller',k:'Kubwa / Ndogo'}]},

  ]

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Measurement — Kupima</p>

      <div style={grid('200px','12px')}>

        {concepts.map(c=>(

          <div key={c.t} style={{...card({padding:'16px'})}}>

            <p style={{fontWeight:700,color:'#c4b5fd',margin:'0 0 10px',fontSize:'.9rem'}}>{c.e} {c.t}</p>

            {c.pairs.map(p=>(

              <div key={p.label}>

                <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'6px'}}>

                  <span style={{fontSize:'1.6rem'}}>{p.big}</span>

                  <span style={{fontSize:'.7rem',color:'#9ca3af',textAlign:'center'}}>{p.label}</span>

                  <span style={{fontSize:'1.6rem'}}>{p.small}</span>

                </div>

                <div style={{...badge('#8b5cf6',{fontSize:'.7rem'}),display:'block',textAlign:'center'}}>{p.k}</div>

              </div>

            ))}

          </div>

        ))}

      </div>

      <div style={{...card({marginTop:'14px',padding:'16px',background:'rgba(139,92,246,0.06)',border:'1px solid rgba(139,92,246,0.2)'})}}>

        <p style={{...label,color:'#c4b5fd',marginBottom:'10px'}}>Non-standard measurement tools:</p>

        <div style={{display:'flex',gap:'10px',flexWrap:'wrap'}}>

          {['Hand span 🤚','Foot steps 👣','String 🧵','Arm length 💪','Sticks 🪵'].map(t=>(

            <span key={t} style={{...badge('#8b5cf6')}}>{t}</span>

          ))}

        </div>

      </div>

    </div>

  )

}



/* ── SWAHILI GREETINGS ── */

function SwahiliGreetingsSection(){

  const [sel,setSel]=useState(null)

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Salamu — Greetings in Kiswahili</p>

      <div style={{overflowX:'auto',marginBottom:'16px'}}>

        <table style={{width:'100%',borderCollapse:'collapse',fontSize:'.85rem',minWidth:'400px'}}>

          <thead>

            <tr style={{borderBottom:'2px solid #1f2937'}}>

              {['English','Kiswahili','Response — Jibu'].map(h=>(

                <th key={h} style={{padding:'10px',textAlign:'left',color:'#6b7280',fontWeight:700,fontSize:'.72rem',textTransform:'uppercase',letterSpacing:'.5px'}}>{h}</th>

              ))}

            </tr>

          </thead>

          <tbody>

            {SWAHILI_GREETINGS.map((g,i)=>(

              <tr key={i} onClick={()=>setSel(sel===i?null:i)}

                style={{borderBottom:'1px solid #111827',cursor:'pointer',background:sel===i?'rgba(20,184,166,0.08)':'transparent',transition:'background .15s'}}>

                <td style={{padding:'10px',color:'#9ca3af'}}>{g.e}</td>

                <td style={{padding:'10px',fontWeight:700,color:'#5eead4',fontSize:'.95rem'}}>{g.k}</td>

                <td style={{padding:'10px',color:'#a5b4fc'}}>{g.r}</td>

              </tr>

            ))}

          </tbody>

        </table>

      </div>

      <div style={{...card({background:'rgba(20,184,166,0.06)',border:'1px solid rgba(20,184,166,0.2)',padding:'14px'})}}>

        <p style={{...label,color:'#5eead4',marginBottom:'8px'}}>🌍 Kiswahili is spoken by over 200 million people in East Africa!</p>

        <p style={{color:'#9ca3af',fontSize:'.8rem',margin:0}}>Kenya · Tanzania · Uganda · Rwanda · DRC · Mozambique</p>

      </div>

    </div>

  )

}



/* ── SWAHILI NUMBERS ── */

function SwahiliNumbersSection(){

  const [sel,setSel]=useState(null)

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Nambari — Numbers in Kiswahili</p>

      <div style={grid('130px','8px')}>

        {SWAHILI_NUMBERS.map(n=>{

          const isSel=sel?.n===n.n

          return(

            <div key={n.n} onClick={()=>setSel(isSel?null:n)}

              style={{...card({cursor:'pointer',textAlign:'center',padding:'14px',

                border:`2px solid ${isSel?'#14b8a6':'#1f2937'}`,

                background:isSel?'rgba(20,184,166,0.12)':'#1a2234',transition:'all .15s'})}}>

              <div style={{fontSize:'1.8rem',fontWeight:900,color:'#5eead4'}}>{n.n}</div>

              <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.85rem',marginTop:'4px'}}>{n.k}</div>

            </div>

          )

        })}

      </div>

    </div>

  )

}



/* ── RE SECTION ── */

function RESection({topic}){

  if(topic.includes('Creation')){

    const creations=['☀️ Sun','🌙 Moon','⭐ Stars','🌍 Earth','💧 Water','🌳 Trees','🐘 Animals','👤 People']

    return(

      <div>

        <p style={sectionTitle('#f9fafb')}>God's Creation — Uumbaji wa Mungu</p>

        <div style={{...card({background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.25)',marginBottom:'16px',padding:'20px'})}}>

          <p style={{fontWeight:700,color:'#a5b4fc',margin:'0 0 8px',fontSize:'1rem'}}>📖 Genesis 1 — In the beginning, God created…</p>

          <div style={grid('155px','12px')}>

            {creations.map(c=>(

              <div key={c} style={{...card({textAlign:'center',padding:'20px 12px',background:'rgba(99,102,241,0.08)'})}}>

                <span style={{fontSize:'3.2rem',display:'block',marginBottom:'8px'}}>{c.split(' ')[0]}</span>

                <div style={{color:'#a5b4fc',fontSize:'1rem',fontWeight:700,marginTop:'4px'}}>{c.split(' ').slice(1).join(' ')}</div>

              </div>

            ))}

          </div>

          <p style={{color:'#c4b5fd',fontSize:'.9rem',margin:'14px 0 0',fontStyle:'italic'}}>

            "God saw all that He had made, and it was very good." — Genesis 1:31

          </p>

        </div>

        <div style={{...card({background:'rgba(34,197,94,0.06)',border:'1px solid rgba(34,197,94,0.2)',padding:'14px'})}}>

          <p style={{fontWeight:700,color:'#86efac',margin:'0 0 8px'}}>You are special! 🌟</p>

          <p style={{color:'#9ca3af',fontSize:'.85rem',margin:0}}>God made you unique. No one else in the whole world is exactly like you! God loves you and cares for you every day.</p>

        </div>

      </div>

    )

  }

  if(topic.includes('Bible')){

    return(

      <div>

        <p style={sectionTitle('#f9fafb')}>Bible Stories — Hadithi za Biblia</p>

        {BIBLE_STORIES.map((s,i)=>(

          <BibleStoryCard key={i} story={s}/>

        ))}

      </div>

    )

  }

  if(topic.includes('Christian Values')){

    return(

      <div>

        <p style={sectionTitle('#f9fafb')}>Christian Values — Maadili ya Kikristo</p>

        <div style={grid('160px','10px')}>

          {CHRISTIAN_VALUES.map(v=>(

            <div key={v.v} style={{...card({textAlign:'center',padding:'16px'})}}>

              <div style={{fontSize:'2.2rem',marginBottom:'6px'}}>{v.e}</div>

              <div style={{fontWeight:800,color:'#f9fafb',fontSize:'.95rem',marginBottom:'4px'}}>{v.v}</div>

              <div style={{...badge('#6366f1',{fontSize:'.65rem',display:'inline-block',marginBottom:'6px'})}}>{v.b}</div>

              <div style={{color:'#9ca3af',fontSize:'.75rem'}}>{v.d}</div>

            </div>

          ))}

        </div>

      </div>

    )

  }

  if(topic.includes('Jesus')){

    const miracles=[

      {t:'Calming the Storm',e:'⛵',ref:'Mark 4:39',l:'Jesus calmed a big storm just by speaking — He said "Peace! Be still!" This shows Jesus has power over nature.'},

      {t:'Feeding 5,000',e:'🐟🍞',ref:'John 6:1–14',l:'With just 5 loaves of bread and 2 fish, Jesus fed over 5,000 people! There was even food left over.'},

      {t:'Healing the Sick',e:'🙌',ref:'Luke 5:17–26',l:'Jesus healed many sick people — the blind could see, the lame could walk. He showed love and compassion to everyone.'},

      {t:'Turning Water to Wine',e:'🍷',ref:'John 2:1–11',l:'At a wedding where they ran out of drink, Jesus turned water into wine. This was His first miracle.'},

    ]

    return(

      <div>

        <p style={sectionTitle('#f9fafb')}>The Life of Jesus Christ</p>

        <div style={{...card({background:'rgba(99,102,241,0.06)',border:'1px solid rgba(99,102,241,0.25)',marginBottom:'16px',padding:'20px'})}}>

          <p style={{fontWeight:700,color:'#a5b4fc',margin:'0 0 8px'}}>🌟 The Birth of Jesus (Luke 2)</p>

          <p style={{color:'#9ca3af',fontSize:'.85rem',margin:'0 0 10px'}}>Jesus was born in Bethlehem, in a stable, to Mary and Joseph. Angels appeared to shepherds in the fields who came to worship the baby. Wise men from the East followed a star and brought gifts.</p>

          <div style={{display:'flex',gap:'8px',flexWrap:'wrap'}}>

            {['Gold 🪙','Frankincense 🌿','Myrrh 💊'].map(g=><span key={g} style={{...badge('#a5b4fc')}}>{g}</span>)}

          </div>

        </div>

        <p style={{...label,marginBottom:'10px',color:'#a5b4fc'}}>Jesus' Miracles & Acts of Kindness:</p>

        {miracles.map(m=>(

          <div key={m.t} style={{...card({marginBottom:'10px',padding:'14px',background:'rgba(99,102,241,0.04)',border:'1px solid rgba(99,102,241,0.15)'})}}>

            <div style={{display:'flex',gap:'12px',alignItems:'flex-start'}}>

              <span style={{fontSize:'1.8rem',flexShrink:0}}>{m.e}</span>

              <div>

                <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.95rem'}}>{m.t} <span style={{...badge('#6366f1',{fontSize:'.65rem',marginLeft:'4px'})}}>{m.ref}</span></div>

                <div style={{color:'#9ca3af',fontSize:'.82rem',marginTop:'4px'}}>{m.l}</div>

              </div>

            </div>

          </div>

        ))}

      </div>

    )

  }

  if(topic.includes('Prayer')){

    const prayers=[

      {t:'Morning Prayer',e:'🌅',p:'Dear God, thank You for this new day. Help me to learn, to be kind, and to do what is right. Amen.'},

      {t:'Meal Time Prayer',e:'🍽️',p:'Thank You God for the food we are about to eat. Bless those who prepared it and those who are hungry. Amen.'},

      {t:'Bedtime Prayer',e:'🌙',p:'Dear God, thank You for today. Forgive me where I went wrong. Keep me and my family safe through the night. Amen.'},

      {t:'School Prayer',e:'📚',p:'Lord God, help me to pay attention and learn well today. Give me wisdom, patience and a good heart. Amen.'},

    ]

    return(

      <div>

        <p style={sectionTitle('#f9fafb')}>Prayer & Church — Sala na Kanisa</p>

        <div style={{...card({background:'rgba(99,102,241,0.08)',border:'1px solid rgba(99,102,241,0.25)',marginBottom:'16px',padding:'16px'})}}>

          <p style={{fontWeight:700,color:'#a5b4fc',margin:'0 0 6px'}}>⛪ What is a Church?</p>

          <p style={{color:'#9ca3af',fontSize:'.85rem',margin:0}}>A church is a place where Christians gather to worship God, pray together, sing songs of praise, and listen to God's Word (the Bible). God lives in the hearts of believers — you are the church too!</p>

        </div>

        <p style={{...label,marginBottom:'10px',color:'#a5b4fc'}}>Simple Prayers — Sala Rahisi:</p>

        {prayers.map(p=>(

          <div key={p.t} style={{...card({marginBottom:'10px',padding:'14px'})}}>

            <p style={{fontWeight:700,color:'#f9fafb',margin:'0 0 6px'}}>{p.e} {p.t}</p>

            <p style={{color:'#c4b5fd',fontSize:'.88rem',fontStyle:'italic',margin:0,lineHeight:1.6}}>"{p.p}"</p>

          </div>

        ))}

      </div>

    )

  }

  return <div style={{color:'#9ca3af',textAlign:'center',padding:'40px'}}>Select a topic above ☝️</div>

}



function BibleStoryCard({story}){
  const [qIdx,setQIdx]=useState(0)
  return(
    <div style={{...card({marginBottom:'20px',padding:'20px'})}}>
      <div style={{display:'flex',gap:'14px',alignItems:'flex-start',marginBottom:'16px',paddingBottom:'14px',borderBottom:'1px solid #1f2937'}}>
        <span style={{fontSize:'2.4rem',flexShrink:0}}>{story.emoji}</span>
        <div style={{flex:1}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',flexWrap:'wrap',gap:'8px'}}>
            <div style={{fontWeight:800,color:'#f9fafb',fontSize:'1.1rem'}}>{story.title}</div>
            <span style={{background:'rgba(99,102,241,0.2)',border:'1px solid rgba(99,102,241,0.4)',borderRadius:'20px',padding:'3px 10px',fontSize:'.72rem',fontWeight:700,color:'#a5b4fc'}}>{story.verse}</span>
          </div>
        </div>
      </div>
      <p style={{color:'#d1d5db',fontSize:'.92rem',lineHeight:1.8,margin:'0 0 16px'}}>{story.story}</p>
      <div style={{display:'inline-block',marginBottom:'16px',padding:'8px 16px',background:'rgba(34,197,94,0.12)',border:'1px solid rgba(34,197,94,0.3)',borderRadius:'20px',color:'#4ade80',fontWeight:700,fontSize:'.88rem'}}>
        💡 Lesson: {story.lesson}
      </div>
      <div style={{background:'rgba(99,102,241,0.08)',borderRadius:'12px',padding:'16px',border:'1px solid rgba(99,102,241,0.2)'}}>
        <p style={{fontSize:'.7rem',fontWeight:700,color:'#a5b4fc',textTransform:'uppercase',letterSpacing:'.5px',marginBottom:'10px'}}>❓ Questions to Think About:</p>
        {story.questions.map((q,i)=>(
          <div key={i} style={{color:'#c4b5fd',fontSize:'.92rem',marginBottom:'8px',padding:'10px 14px',
            background:qIdx===i?'rgba(99,102,241,0.2)':'rgba(99,102,241,0.05)',borderRadius:'8px',cursor:'pointer',lineHeight:1.65}}
            onClick={()=>setQIdx(i)}>
            Q{i+1}: {q}
          </div>
        ))}
      </div>
    </div>
  )
}


function MusicMovementSection(){

  const songs=[

    {t:'Head, Shoulders, Knees & Toes',e:'🎵',actions:'Touch each body part as you sing — head, shoulders, knees, toes, eyes, ears, mouth and nose!'},

    {t:'If You\'re Happy and You Know It',e:'👏',actions:'Clap your hands · Stamp your feet · Shout "Hooray!" · Turn around!'},

    {t:'The Alphabet Song',e:'🎼',actions:'Point to each letter on the chart as you sing A-B-C-D-E-F-G…'},

    {t:'Old MacDonald Had a Farm',e:'🐄',actions:'Moo like a cow · Baa like a sheep · Cluck like a chicken — make the sounds!'},

    {t:'Twinkle Twinkle Little Star',e:'⭐',actions:'Raise hands up for stars · Wave side to side · Open and close hands like twinkling'},

    {t:'Ten Green Bottles',e:'🍾',actions:'Hold up 10 fingers, fold one down as each bottle "falls" — great for counting backwards!'},

  ]

  const movements=[

    {a:'Hop on one foot',e:'🦘',s:'Balance! Strengthens legs and coordination'},

    {a:'Jump with both feet',e:'🐸',s:'Builds strong leg muscles'},

    {a:'Run and stop',e:'🏃',s:'Develops speed control and listening skills'},

    {a:'Walk like an elephant',e:'🐘',s:'Slow, heavy steps — great for body awareness'},

    {a:'Gallop like a horse',e:'🐴',s:'Skip-step movement — develops rhythm'},

    {a:'Crawl like a crab',e:'🦀',s:'Great for core strength'},

    {a:'Stretch up tall',e:'🙆',s:'Reach up high like a giraffe!'},

    {a:'Roll like a log',e:'🪵',s:'Develops spatial awareness'},

  ]

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Music & Movement — Muziki na Harakati</p>

      <p style={{...label,marginBottom:'10px',color:'#fdba74'}}>🎵 Action Songs:</p>

      <div style={grid('200px','10px',)}>

        {songs.map(s=>(

          <div key={s.t} style={{...card({padding:'14px'})}}>

            <div style={{fontWeight:700,color:'#f9fafb',margin:'0 0 4px',fontSize:'.9rem'}}>{s.e} {s.t}</div>

            <div style={{color:'#9ca3af',fontSize:'.75rem'}}>{s.actions}</div>

          </div>

        ))}

      </div>

      <p style={{...label,marginBottom:'10px',color:'#fdba74',marginTop:'16px'}}>🏃 Movement Activities:</p>

      <div style={grid('160px','10px')}>

        {movements.map(m=>(

          <div key={m.a} style={{...card({textAlign:'center',padding:'14px'})}}>

            <div style={{fontSize:'2rem',marginBottom:'6px'}}>{m.e}</div>

            <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.82rem',marginBottom:'4px'}}>{m.a}</div>

            <div style={{color:'#9ca3af',fontSize:'.7rem'}}>{m.s}</div>

          </div>

        ))}

      </div>

    </div>

  )

}



/* ── ART / CRAFTS ── */

function ArtSection({topic}){

  const items=[

    {t:'Finger Painting',e:'🖐️',steps:['Dip your finger in paint','Press it on the paper','Make dots, lines or shapes!'],mat:'Paint, paper'},

    {t:'Leaf Printing',e:'🍃',steps:['Collect a leaf from outside','Paint one side of the leaf','Press it firmly on paper','Lift to see the print!'],mat:'Leaves, paint, paper'},

    {t:'Playdough Modelling',e:'🎨',steps:['Roll it into a ball','Flatten it to make a pancake','Roll it into a snake','Shape it into animals or pots!'],mat:'Playdough or clay'},

    {t:'Paper Mosaic',e:'🗒️',steps:['Tear coloured paper into small pieces','Draw a simple shape on white paper','Paste the pieces inside the shape'],mat:'Coloured paper, glue'},

    {t:'Bead Threading',e:'📿',steps:['Choose beads of different colours','Thread a needle or string','Create a colour pattern','Tie the ends together'],mat:'Beads, thread'},

    {t:'Origami Folding',e:'🪂',steps:['Start with a square of paper','Fold in half diagonally','Follow the shape step by step','No cutting — just folding!'],mat:'Square paper'},

  ]

  const instruments=[

    {n:'Drum',e:'🥁',k:'Ngoma',s:'Stretched skin over a frame — beat with hands or sticks'},

    {n:'Shaker / Rattle',e:'🪇',k:'Kayamba',s:'Fill a sealed container with seeds or pebbles'},

    {n:'Sticks',e:'🪵',k:'Vijiti',s:'Two sticks tapped together to keep a beat'},

    {n:'Whistle',e:'🎵',k:'Filimbi',s:'Blow to make a high sound'},

    {n:'Hand Clapping',e:'👏',k:'Kupiga makofi',s:'The simplest instrument — your own hands!'},

  ]

  if(topic.includes('Crafts')||topic.includes('Art')){

    return(

      <div>

        <p style={sectionTitle('#f9fafb')}>Art & Crafts — Sanaa na Ufundi</p>

        <div style={grid('200px','10px')}>

          {items.map(it=>(

            <div key={it.t} style={{...card({padding:'14px'})}}>

              <div style={{fontSize:'2rem',marginBottom:'6px'}}>{it.e}</div>

              <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.9rem',marginBottom:'6px'}}>{it.t}</div>

              <div style={{...badge('#f97316',{display:'inline-block',fontSize:'.65rem',marginBottom:'8px'})}}>🧰 {it.mat}</div>

              {it.steps.map((s,i)=>(

                <div key={i} style={{color:'#9ca3af',fontSize:'.75rem',marginBottom:'3px'}}>

                  <span style={{color:'#fdba74',fontWeight:700}}>{i+1}.</span> {s}

                </div>

              ))}

            </div>

          ))}

        </div>

      </div>

    )

  }

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>Music Instruments — Vyombo vya Muziki</p>

      <div style={grid('160px','10px')}>

        {instruments.map(i=>(

          <div key={i.n} style={{...card({textAlign:'center',padding:'16px'})}}>

            <div style={{fontSize:'2.4rem',marginBottom:'6px'}}>{i.e}</div>

            <div style={{fontWeight:700,color:'#f9fafb',fontSize:'.9rem'}}>{i.n}</div>

            <div style={{color:'#5eead4',fontSize:'.75rem',marginBottom:'4px'}}>{i.k}</div>

            <div style={{color:'#9ca3af',fontSize:'.7rem'}}>{i.s}</div>

          </div>

        ))}

      </div>

    </div>

  )

}



/* ── STUDY NOTES ── */

function StudyNotes({subj,cls}){

  const subjectNoteKeys = {
    'Language Activities':['alphabet','vowels','syllables','fib'],
    'Mathematical Activities':['numbers','shapes','multiplication'],
    'Environmental Activities':['animals','body','weather','plants','health'],
    'Religious Education':['creation','bible'],
    'English':['alphabet','vowels','syllables','fib'],
    'Mathematics':['numbers','shapes','multiplication'],
    'Kiswahili':['alphabet'],
    'Creative Activities':[],
    'Creative Arts':[],
  }
  const keys = subjectNoteKeys[subj] || Object.keys(CURRICULUM_NOTES)
  const allNotes = keys.length ? keys.map(k=>CURRICULUM_NOTES[k]).filter(Boolean) : Object.values(CURRICULUM_NOTES)

  return(

    <div>

      <p style={sectionTitle('#f9fafb')}>📋 Study Notes — Maelezo ya Masomo</p>

      <p style={{color:'#9ca3af',fontSize:'.85rem',marginBottom:'16px'}}>

        These are the <strong style={{color:'#f9fafb'}}>Specific Learning Outcomes</strong> and <strong style={{color:'#f9fafb'}}>Key Inquiry Questions</strong> for <span style={{color:'#a5b4fc'}}>{cls} — {subj}</span>

      </p>

      {allNotes.map((n,i)=>(

        <StudyNoteCard key={i} note={n}/>

      ))}

    </div>

  )

}



function StudyNoteCard({note}){
  return(
    <div style={{marginBottom:'32px',paddingBottom:'28px',borderBottom:'1px solid #1f2937'}}>
      <p style={{fontWeight:900,color:'#f9fafb',fontSize:'1.15rem',margin:'0 0 16px'}}>{note.title}</p>
      <p style={{fontSize:'.75rem',fontWeight:700,color:'#86efac',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:'12px'}}>✅ Learning Outcomes</p>
      {note.outcomes.map((o,i)=>(
        <div key={i} style={{color:'#d1fae5',fontSize:'1rem',marginBottom:'12px',display:'flex',gap:'12px',lineHeight:1.75}}>
          <span style={{color:'#22c55e',flexShrink:0,fontSize:'1.1rem',marginTop:'1px'}}>•</span>{o}
        </div>
      ))}
      <p style={{fontSize:'.75rem',fontWeight:700,color:'#a5b4fc',textTransform:'uppercase',letterSpacing:'.8px',marginBottom:'12px',marginTop:'20px'}}>❓ Key Inquiry Questions</p>
      {note.inquiries.map((q,i)=>(
        <div key={i} style={{color:'#e0e7ff',fontSize:'1rem',marginBottom:'12px',display:'flex',gap:'12px',lineHeight:1.75}}>
          <span style={{color:'#6366f1',flexShrink:0,fontWeight:800,minWidth:'28px'}}>Q{i+1}.</span>{q}
        </div>
      ))}
      <div style={{marginTop:'18px',borderLeft:'4px solid #fbbf24',paddingLeft:'16px'}}>
        <span style={{color:'#fde68a',fontSize:'1rem',lineHeight:1.75}}>{note.tip}</span>
      </div>
    </div>
  )
}


function QuizMode({topic, grade, subject, token, onClose}){
  const qs = QUIZ_QUESTIONS[topic] || []
  const [idx,setIdx] = useState(0)
  const [chosen,setChosen] = useState(null)
  const [score,setScore] = useState(0)
  const [done,setDone] = useState(false)
  const [saved,setSaved] = useState(false)

  if(!qs.length) return(
    <div style={{textAlign:'center',padding:'40px',color:'#6b7280'}}>
      <div style={{fontSize:'2rem',marginBottom:'8px'}}>??</div>
      <p>Quiz for this topic coming soon!</p>
      <button onClick={onClose} style={{marginTop:'12px',padding:'8px 18px',borderRadius:'8px',background:'#1f2937',border:'1px solid #374151',color:'#9ca3af',cursor:'pointer'}}>Close</button>
    </div>
  )

  const q = qs[idx]
  const isLast = idx === qs.length - 1

  const handleAnswer = (opt) => {
    if(chosen) return
    const correct = opt === q.a
    setChosen(opt)
    if(correct) setScore(s => s+1)
  }

  const next = async () => {
    if(isLast){
      setDone(true)
      try {
        await fetch('/api/studytime/quiz', {
          method:'POST',
          headers:{'Content-Type':'application/json','Authorization':'Bearer '+token},
          body: JSON.stringify({grade, subject, topic, score: chosen===q.a?score+1:score, total: qs.length})
        })
        setSaved(true)
      } catch {}
    } else {
      setIdx(i => i+1)
      setChosen(null)
    }
  }

  const finalScore = chosen===q.a ? score+1 : score
  const pct = Math.round((finalScore/qs.length)*100)

  if(done) return(
    <div style={{textAlign:'center',padding:'32px 20px'}}>
      <div style={{fontSize:'3rem',marginBottom:'12px'}}>{pct>=80?'??':pct>=60?'?':'??'}</div>
      <h3 style={{fontSize:'1.4rem',fontWeight:900,color:'#f9fafb',margin:'0 0 6px'}}>{pct>=80?'Excellent!':pct>=60?'Good job!':'Keep studying!'}</h3>
      <div style={{fontSize:'3rem',fontWeight:900,color:pct>=80?'#4ade80':pct>=60?'#fbbf24':'#f87171',margin:'12px 0'}}>{finalScore}/{qs.length}</div>
      <div style={{color:'#6b7280',fontSize:'.85rem',marginBottom:'20px'}}>{pct}% correct{saved?' — Saved ?':''}</div>
      <div style={{display:'flex',gap:'10px',justifyContent:'center',flexWrap:'wrap'}}>
        <button onClick={()=>{setIdx(0);setChosen(null);setScore(0);setDone(false)}}
          style={{padding:'10px 20px',borderRadius:'10px',background:'rgba(99,102,241,0.15)',border:'1px solid #6366f1',color:'#a5b4fc',fontWeight:700,cursor:'pointer'}}>
          Try Again ?
        </button>
        <button onClick={onClose}
          style={{padding:'10px 20px',borderRadius:'10px',background:'#1f2937',border:'1px solid #374151',color:'#9ca3af',fontWeight:700,cursor:'pointer'}}>
          Back to Topic
        </button>
      </div>
    </div>
  )

  return(
    <div style={{padding:'4px'}}>
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:'16px'}}>
        <span style={{fontSize:'.78rem',fontWeight:700,color:'#6b7280',textTransform:'uppercase',letterSpacing:'.5px'}}>Question {idx+1} of {qs.length}</span>
        <div style={{display:'flex',gap:'4px'}}>
          {qs.map((_,i)=>(
            <div key={i} style={{width:'20px',height:'4px',borderRadius:'2px',background:i<idx?'#22c55e':i===idx?'#6366f1':'#1f2937',transition:'background .2s'}}/>
          ))}
        </div>
        <span style={{fontSize:'.78rem',color:'#22c55e',fontWeight:700}}>{score} correct</span>
      </div>
      <div style={{background:'rgba(99,102,241,0.06)',border:'1px solid rgba(99,102,241,0.2)',borderRadius:'14px',padding:'24px',marginBottom:'16px',textAlign:'center'}}>
        <p style={{fontSize:'1.1rem',fontWeight:700,color:'#f9fafb',margin:0,lineHeight:1.5}}>{q.q}</p>
      </div>
      <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:'10px',marginBottom:'16px'}}>
        {q.o.map(opt=>{
          const isChosen = chosen===opt
          const isCorrect = opt===q.a
          const col = !chosen?'#374151':isChosen?(isCorrect?'#22c55e':'#ef4444'):isCorrect?'#22c55e':'#1f2937'
          return(
            <button key={opt} onClick={()=>handleAnswer(opt)} disabled={!!chosen}
              style={{padding:'14px',borderRadius:'12px',border:'2px solid '+col,
                background:!chosen?'#111827':isChosen?(isCorrect?'rgba(34,197,94,0.15)':'rgba(239,68,68,0.15)'):isCorrect?'rgba(34,197,94,0.08)':'#0a0e17',
                color:!chosen?'#f9fafb':isChosen?(isCorrect?'#4ade80':'#f87171'):isCorrect?'#4ade80':'#6b7280',
                fontWeight:700,fontSize:'.95rem',cursor:chosen?'default':'pointer',transition:'all .15s'}}>
              {opt}
            </button>
          )
        })}
      </div>
      {chosen&&(
        <div style={{textAlign:'center'}}>
          <p style={{color:chosen===q.a?'#4ade80':'#f87171',fontWeight:700,marginBottom:'12px',fontSize:'.95rem'}}>
            {chosen===q.a?'? Correct!':'? Answer: '+q.a}
          </p>
          <button onClick={next}
            style={{padding:'12px 32px',borderRadius:'10px',background:'linear-gradient(135deg,#6366f1,#4f46e5)',color:'#fff',fontWeight:700,border:'none',cursor:'pointer',fontSize:'.95rem'}}>
            {isLast?'See Results ?':'Next Question ?'}
          </button>
        </div>
      )}
    </div>
  )
}
function renderTopic(cls, subj, topic){

  const t=topic

  if(t==='Uppercase ABC'||t==='Alphabet Review')return <LetterChart upper={true} showKiswahili={cls==='Grade 1'}/>

  if(t==='Lowercase abc')return <LetterChart upper={false} showKiswahili={false}/>

  if(t.includes('Vowel')||t.includes('Irabu'))return <VowelsConsonants/>

  if(t.includes('Consonant')||t.includes('Konsonanti'))return <VowelsConsonants/>

  if(t==='Syllables'||t==='Syllables & Blends')return <SyllableChart/>

  if(t==='Fill in the Blank')return <FillInBlank level={cls}/>

  if(t==='Simple Words')return <SimpleWordsSection level={cls}/>

  if(t.includes('Numbers 1–50'))return <NumberChart max={50}/>
  if(t.includes('Numbers 1–20'))return <NumberChart max={20}/>

  if(t.includes('Numbers 1–100'))return <NumberChart max={100}/>

  if(t==='Shapes')return <ShapesSection/>

  if(t.includes('Colour')||t.includes('Color')||t.includes('Rangi — Colours'))return <ColoursSection/>

  if(t==='Patterns')return <PatternsSection/>

  if(t==='Counting Fun')return <CountingFun/>

  if(t==='Measurement')return <MeasurementSection/>

  if(t==='Addition')return <ArithmeticPractice op="+"/>

  if(t==='Subtraction')return <ArithmeticPractice op="-"/>

  if(t==='Multiplication Tables')return <MultiplicationTables/>

  if(t==='Wild Animals')return <AnimalsSection type="wild"/>

  if(t==='Domestic Animals')return <AnimalsSection type="domestic"/>

  if(t==='Wild & Domestic Animals')return <AnimalsSection type="both"/>

  if(t==='Wanyama — Animals')return <AnimalsSection type="both"/>

  if(t==='Body Parts')return <BodyPartsSection/>

  if(t==='Weather')return <WeatherSection/>

  if(t==='Plants & Water'||t==='Plants')return <PlantsSection/>

  if(t==='Health & Safety')return <HealthSafetySection/>

  if(t==='My Family')return <FamilySection/>

  if(t==='My School')return <MySchoolSection/>

  if(t==='Community Helpers')return <CommunityHelpersSection/>

  if(t==='Salamu — Greetings')return <SwahiliGreetingsSection/>

  if(t==='Nambari — Numbers')return <SwahiliNumbersSection/>

  if(t==='Rangi — Colours')return <ColoursSection/>

  if(t==='Music & Movement'||t==='Music & Dance')return <MusicMovementSection/>

  if(t.includes('Crafts')||t==='Colours & Drawing'||t==='Colours Chart'||t==='Art Techniques')return <ArtSection topic={t}/>

  if(t==='Movement Skills')return <MusicMovementSection/>

  if(t==="God's Creation"||t==='Bible Stories'||t==='Christian Values'||t==='Life of Jesus'||t==='Prayer & Church')return <RESection topic={t}/>

  if(t==='Study Notes')return <StudyNotes subj={subj} cls={cls}/>

  if(t==='Mazungumzo')return <SwahiliGreetingsSection/>

  if(t==='Colours Chart')return <ColoursSection/>

  if(t==='Colours')return <ColoursSection/>

  // fallback

  return(

    <div style={{textAlign:'center',padding:'48px',color:'#6b7280'}}>

      <div style={{fontSize:'3rem',marginBottom:'12px'}}>🚀</div>

      <div style={{fontSize:'1rem',fontWeight:700,color:'#9ca3af'}}>Content for "{t}" coming soon!</div>

      <div style={{fontSize:'.8rem',marginTop:'6px'}}>Try another topic above.</div>

    </div>

  )

}



/*════════════════════════════════════════════════════

  MAIN DASHBOARD COMPONENT WITH HAMBURGER & SIDEBAR

════════════════════════════════════════════════════*/

function Onboarding({onStart}){
  const [grade,setGrade]=useState('')
  const [subj,setSubj]=useState('')
  const subjects=grade?(GRADE_SUBJECTS_MAP[grade]||[]):[]
  const icons={'Language Activities':'','Mathematical Activities':'','Creative Activities':'','Environmental Activities':'','Religious Education':'','English':'','Mathematics':'','Kiswahili':'','Creative Arts':'','Creative Arts & Sports':'','Science & Technology':'','Social Studies':'','Integrated Science':'','Health Education':'','Agriculture':''}
  const gradeIcons={'PP1':'','PP2':'','Grade 1':'','Grade 2':'','Grade 3':'','Grade 4':'','Grade 5':'','Grade 6':'','Grade 7':'','Grade 8':'','Grade 9':''}
  const can=grade&&subj
  return(
    <div style={{minHeight:'100vh',background:'#0a0e17',display:'flex',alignItems:'center',justifyContent:'center',padding:'24px'}}>
      <div style={{width:'100%',maxWidth:'420px'}}>
        <div style={{textAlign:'center',marginBottom:'40px'}}>
          <div style={{fontSize:'3rem',marginBottom:'12px'}}></div>
          <h1 style={{fontSize:'2rem',fontWeight:900,color:'#f9fafb',margin:'0 0 6px',letterSpacing:'-0.5px'}}>Study Time</h1>
          <p style={{color:'#6b7280',fontSize:'.9rem',margin:0}}>Select your class and subject to begin</p>
        </div>
        <div style={{marginBottom:'20px'}}>
          <label style={{display:'block',fontSize:'.72rem',fontWeight:700,color:'#6b7280',textTransform:'uppercase',letterSpacing:'.5px',marginBottom:'8px'}}>Class  Darasa</label>
          <div style={{position:'relative'}}>
            <select value={grade} onChange={e=>{setGrade(e.target.value);setSubj('')}}
              style={{width:'100%',padding:'14px 40px 14px 16px',borderRadius:'12px',background:'#111827',border:'1px solid '+(grade?'#6366f1':'#1f2937'),color:grade?'#f9fafb':'#6b7280',fontSize:'1rem',fontWeight:600,cursor:'pointer',outline:'none',appearance:'none'}}>
              <option value="">Choose your class...</option>
              {['PP1','PP2','Grade 1','Grade 2','Grade 3','Grade 4','Grade 5','Grade 6','Grade 7','Grade 8','Grade 9'].map(g=>(
                <option key={g} value={g}>{gradeIcons[g]} {g}</option>
              ))}
            </select>
            <span style={{position:'absolute',right:'14px',top:'50%',transform:'translateY(-50%)',color:'#6b7280',pointerEvents:'none'}}></span>
          </div>
        </div>
        {grade&&(
          <div style={{marginBottom:'28px'}}>
            <label style={{display:'block',fontSize:'.72rem',fontWeight:700,color:'#6b7280',textTransform:'uppercase',letterSpacing:'.5px',marginBottom:'8px'}}>Subject  Somo</label>
            <div style={{display:'flex',flexDirection:'column',gap:'8px'}}>
              {subjects.map(s=>{
                const isSel=subj===s
                return(
                  <button key={s} onClick={()=>setSubj(s)}
                    style={{padding:'12px 16px',borderRadius:'10px',textAlign:'left',border:'1px solid '+(isSel?'#6366f1':'#1f2937'),background:isSel?'rgba(99,102,241,0.15)':'#111827',color:isSel?'#a5b4fc':'#9ca3af',fontWeight:isSel?700:400,fontSize:'.9rem',cursor:'pointer',display:'flex',alignItems:'center',gap:'10px',transition:'all .12s'}}>
                    <span>{icons[s]||''}</span>{s}{isSel&&<span style={{marginLeft:'auto',color:'#6366f1'}}></span>}
                  </button>
                )
              })}
            </div>
          </div>
        )}
        <button onClick={()=>can&&onStart(grade,subj)} disabled={!can}
          style={{width:'100%',padding:'16px',borderRadius:'12px',fontSize:'1rem',fontWeight:700,border:'none',cursor:can?'pointer':'not-allowed',background:can?'linear-gradient(135deg,#6366f1,#4f46e5)':'#1f2937',color:can?'#fff':'#374151',transition:'all .2s'}}>
          {can?('Start Learning '+gradeIcons[grade]+' '):'Select class and subject to continue'}
        </button>
        {can&&<p style={{textAlign:'center',color:'#6b7280',fontSize:'.78rem',marginTop:'12px'}}>{grade}  {subj}</p>}
      </div>
    </div>
  )
}

export default function StudyTime(){

  const [screen,setScreen]=useState('onboard')
  const [showSwahili,setShowSwahili]=useState(true)
  const [showQuiz,setShowQuiz]=useState(false)
  const [visited,setVisited]=useState({})
  const [favourites,setFavourites]=useState({})
  const [quizScores,setQuizScores]=useState({})
  const token = localStorage.getItem('token') || sessionStorage.getItem('token') || ''

  const api = useCallback(async (url,method='GET',body=null)=>{
    const opts = {method,headers:{'Content-Type':'application/json','Authorization':'Bearer '+token}}
    if(body) opts.body = JSON.stringify(body)
    const r = await fetch(url,opts)
    return r.json()
  },[token])

  useEffect(()=>{
    if(!token) return
    api('/api/studytime/progress').then(rows=>{
      const map={}
      rows.forEach(r=>{ map[r.grade+'|'+r.subject+'|'+r.topic]=true })
      setVisited(map)
    }).catch(()=>{})
    api('/api/studytime/favourites').then(rows=>{
      const map={}
      rows.forEach(r=>{ map[r.grade+'|'+r.subject+'|'+r.topic]=true })
      setFavourites(map)
    }).catch(()=>{})
    api('/api/studytime/quiz/results').then(rows=>{
      const map={}
      rows.forEach(r=>{ map[r.grade+'|'+r.subject+'|'+r.topic]=Math.round((r.best_score/r.total)*100) })
      setQuizScores(map)
    }).catch(()=>{})
  },[api,token])

  const markVisited = useCallback((g,s,t)=>{
    const key=g+'|'+s+'|'+t
    if(visited[key]) return
    setVisited(v=>({...v,[key]:true}))
    api('/api/studytime/progress','POST',{grade:g,subject:s,topic:t}).catch(()=>{})
  },[visited,api])

  const toggleFav = useCallback((g,s,t)=>{
    const key=g+'|'+s+'|'+t
    setFavourites(f=>({...f,[key]:!f[key]}))
    api('/api/studytime/favourite','POST',{grade:g,subject:s,topic:t}).catch(()=>{})
  },[api])
  const [sidebarOpen, setSidebarOpen] = useState(false)

  const [cls, setCls] = useState('PP1')

  const [subj, setSubj] = useState('Language Activities')

  const [topic, setTopic] = useState('Uppercase ABC')

  useEffect(()=>{
    if(screen==='study') markVisited(cls,subj,topic)
  },[screen,topic,cls,subj])



  if(screen==='onboard') return <Onboarding onStart={(g,s)=>{setCls(g);setSubj(s);const t=SUBJECT_TOPICS[g]?.[s];setTopic(t?t[0]:'Study Notes');setScreen('study')}} />

  const handleClassChange = (newCls) => {

    setCls(newCls)

    const firstSubj = CLASS_SUBJECTS[newCls][0]

    setSubj(firstSubj)

    setTopic(SUBJECT_TOPICS[newCls][firstSubj][0])

  }



  const handleSubjChange = (newSubj) => {

    setSubj(newSubj)

    setTopic(SUBJECT_TOPICS[cls][newSubj][0])

  }



  const col = SUBJECT_COLORS[subj] || SUBJECT_COLORS['Language Activities']

  const topics = SUBJECT_TOPICS[cls]?.[subj] || []



  const subjEmojis = {

    'Language Activities':'📖','Mathematical Activities':'🔢','Creative Activities':'🎨',

    'Environmental Activities':'🌿','Religious Education':'✝️',

    'English':'📖','Mathematics':'🔢','Kiswahili':'🌍','Creative Arts':'🎨',

  }



  return (

    <div style={{ minHeight: '100vh', background: '#0a0e17' }}>

      {/* OVERLAY */}

      {sidebarOpen && (

        <div

          onClick={() => setSidebarOpen(false)}

          style={{

            position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.5)',

            zIndex: 90, backdropFilter: 'blur(2px)', WebkitBackdropFilter: 'blur(2px)'

          }}

        />

      )}



      {/* SIDEBAR */}

      <aside style={{

        position: 'fixed', top: 0, left: 0, height: '100vh', width: '280px',

        background: '#0d1117', borderRight: '1px solid #1f2937', zIndex: 100,

        transform: sidebarOpen ? 'translateX(0)' : 'translateX(-100%)',

        transition: 'transform 0.25s ease', overflowY: 'auto', display: 'flex', flexDirection: 'column',

        boxShadow: '4px 0 24px rgba(0,0,0,0.5)'

      }}>

        <div style={{ padding: '16px', borderBottom: '1px solid #1f2937', display: 'flex', alignItems: 'center', justifyContent: 'space-between' }}>

          <span style={{ fontWeight: 800, fontSize: '1.1rem', color: '#f9fafb' }}>📚 Study Time</span>

          <button onClick={() => setSidebarOpen(false)} style={{

            background: '#111827', border: '1px solid #1f2937', color: '#9ca3af',

            borderRadius: '8px', width: '32px', height: '32px', fontSize: '1.1rem', cursor: 'pointer',

            display: 'flex', alignItems: 'center', justifyContent: 'center'

          }}>✕</button>

        </div>



        <div style={{ flex: 1, overflowY: 'auto', padding: '14px 14px' }}>

          {/* SUBJECT LIST */}

          <p style={{ fontSize: '0.7rem', fontWeight: 700, color: '#6b7280', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: '6px' }}>Subject — Somo</p>

          <div style={{ display: 'flex', flexDirection: 'column', gap: '4px', marginBottom: '16px' }}>

            {CLASS_SUBJECTS[cls].map(s => (

              <button key={s} onClick={() => handleSubjChange(s)} style={{

                padding: '10px 12px', borderRadius: '8px', fontWeight: subj===s?700:400, fontSize: '0.8rem',

                cursor: 'pointer', border: `1px solid ${subj===s?col.acc:'transparent'}`,

                background: subj===s?col.bg:'transparent', color: subj===s?col.txt:'#9ca3af',

                textAlign: 'left', transition: 'all 0.12s', display: 'flex', alignItems: 'center', gap: '6px'

              }}>

                <span>{subjEmojis[s]}</span> {s}

              </button>

            ))}

          </div>



          {/* TOPIC LIST */}

          <p style={{ fontSize: '0.7rem', fontWeight: 700, color: '#6b7280', textTransform: 'uppercase', letterSpacing: '0.5px', marginBottom: '6px' }}>Topics</p>

          <div style={{ display: 'flex', flexDirection: 'column', gap: '2px' }}>

            {topics.map(t => (

              <button key={t} onClick={() => { setTopic(t); setSidebarOpen(false) }} style={{

                padding: '9px 12px', borderRadius: '8px', fontWeight: topic===t?700:400, fontSize: '0.78rem',

                cursor: 'pointer', border: '1px solid transparent',

                background: topic===t?'rgba(99,102,241,0.1)':'transparent',

                color: topic===t?'#c4b5fd':'#9ca3af', textAlign: 'left', transition: 'all 0.12s'

              }}>

                {t}

              </button>

            ))}

          </div>

        </div>



        <div style={{ padding: '12px 14px', borderTop: '1px solid #1f2937', fontSize: '0.7rem', color: '#6b7280', lineHeight: 1.5, background: 'rgba(99,102,241,0.03)' }}>

          💡 <strong style={{color:'#9ca3af'}}>Study Tip:</strong> Go through one topic at a time. Read the Study Notes for each section.

        </div>

      </aside>



      {/* MAIN CONTENT */}

      <div style={{ paddingLeft: sidebarOpen ? '280px' : '0', transition: 'padding-left 0.25s ease' }}>

        {/* TOPBAR */}

        <header style={{

          display: 'flex', alignItems: 'center', gap: '14px', padding: '12px 18px',

          borderBottom: '1px solid #1f2937', background: '#0a0e17', position: 'sticky', top: 0, zIndex: 50

        }}>

          <button onClick={() => setSidebarOpen(true)} style={{

            width: '40px', height: '40px', borderRadius: '10px', border: '1px solid #1f2937',

            background: '#111827', color: '#9ca3af', fontSize: '1.4rem', cursor: 'pointer',

            display: 'flex', alignItems: 'center', justifyContent: 'center', flexShrink: 0

          }} aria-label="Open menu">

            ☰

          </button>

          <div>

            <h1 style={{ fontSize: '1.25rem', fontWeight: 800, color: '#f9fafb', margin: 0, letterSpacing: '-0.3px' }}>

              📚 Study Time

            </h1>

            <p style={{ fontSize: '0.75rem', color: '#6b7280', margin: 0 }}>

              {cls} · {subj} · {topic}

            </p>

          </div>

        </header>



        {/* CONTENT PANEL */}

        <div style={{ padding: '20px' }}>

          <div style={{

            background: '#0f1520', border:`1px solid ${col.border}`, borderRadius:'16px',

            padding:'20px', minHeight:'300px'

          }}>

            {showQuiz
              ? <QuizMode topic={topic} grade={cls} subject={subj} token={token} onClose={()=>setShowQuiz(false)}/>
              : renderTopic(cls, subj, topic)
            }

          </div>



          <div style={{ marginTop:'16px', padding:'10px 14px', background:'rgba(99,102,241,0.05)', borderRadius:'10px',

            border:'1px solid rgba(99,102,241,0.15)', display:'flex', gap:'10px', alignItems:'center', flexWrap:'wrap' }}>

            <span style={{fontSize:'1.2rem'}}>💡</span>

            <span style={{color:'#6b7280', fontSize:'.78rem'}}>

              <strong style={{color:'#9ca3af'}}>Study Tip:</strong> Use the menu ☰ to switch classes, subjects, and topics.

              Content covers PP1 → PP2 → Grade 1.

            </span>

          </div>

        </div>

      </div>

    </div>

  )

}





























